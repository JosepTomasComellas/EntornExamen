@inherits LayoutComponentBase
@implements IDisposable
@inject UserStateService UserState
@inject NavigationManager Nav
@inject ProtectedLocalStorage LocalStorage
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResources> Loc
@inject BrandConfig Brand

<MudThemeProvider Theme="_theme" IsDarkMode="@_darkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="@(_darkMode ? "app-dark" : "app-light")">
    <MudAppBar Elevation="3" Style="@($"background:{Brand.ColorAppBar}")">
        <!-- Logo clicable → dashboard del rol actiu -->
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0" Style="min-width:0;flex-shrink:0">
            <a href="@LogoHref" style="display:block;line-height:0">
                <MudImage Src="@Brand.LogoUrl" Height="44" Style="display:block" />
            </a>
        </MudStack>

        <MudSpacer />

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Style="min-width:0">
            @if (UserState.IsLoggedIn)
            {
                <MudChip T="string" Size="Size.Small"
                         Style="color:white;background:rgba(255,255,255,.15);flex-shrink:0">
                    @UserState.Role
                </MudChip>
                <MudText Typo="Typo.body2"
                         Style="color:rgba(255,255,255,.9);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:260px"
                         Class="d-none d-sm-block">
                    @UserState.NomComplet
                </MudText>
            }
            @if (UserState.IsProfessor)
            {
                <MudIconButton Icon="@Icons.Material.Filled.AccountCircle"
                               Color="Color.Inherit" title="@Loc["Nav_MyProfile"]"
                               Href="/professor/perfil" />
            }
            <!-- Selector d'idioma — visible per a tothom -->
            <MudMenu Icon="@Icons.Material.Filled.Translate" Color="Color.Inherit"
                     title="@Loc["Nav_Language"]" Dense="true" AnchorOrigin="Origin.BottomRight">
                <MudMenuItem OnClick='async () => await JS.InvokeVoidAsync("setCulture", "ca")'>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.body2">@Loc["Lang_Catalan"]</MudText>
                        @if (System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ca")
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" />
                        }
                    </MudStack>
                </MudMenuItem>
                <MudMenuItem OnClick='async () => await JS.InvokeVoidAsync("setCulture", "es")'>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.body2">@Loc["Lang_Spanish"]</MudText>
                        @if (System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "es")
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" />
                        }
                    </MudStack>
                </MudMenuItem>
            </MudMenu>
            @if (UserState.IsProfessor)
            {
                <!-- Selector de color primari — només professors -->
                <MudMenu Icon="@Icons.Material.Filled.Palette" Color="Color.Inherit"
                         title="@Loc["Nav_ColorTheme"]" Dense="true" AnchorOrigin="Origin.BottomRight">
                    @foreach (var (name, hex) in _colorOptions)
                    {
                        <MudMenuItem OnClick="() => ChangeColorAsync(hex)">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <div style="width:16px;height:16px;border-radius:50%;background:@hex;
                                            border:2px solid rgba(255,255,255,.3)"></div>
                                <MudText Typo="Typo.body2">@name</MudText>
                                @if (_primaryColor == hex)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" />
                                }
                            </MudStack>
                        </MudMenuItem>
                    }
                </MudMenu>
            }
            <!-- Mode fosc — visible per a tothom -->
            <MudIconButton Icon="@(_darkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit"
                           title="@(_darkMode ? Loc["Nav_LightMode"].Value : Loc["Nav_DarkMode"].Value)"
                           OnClick="ToggleDarkMode" />
            @if (UserState.IsLoggedIn)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Logout"
                               Color="Color.Inherit"
                               title="@string.Format(Loc["Nav_LogoutTitle"].Value, UserState.NomComplet)"
                               OnClick="Logout" />
            }
        </MudStack>
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-8">
            @if (!_sessionChecked)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-8" />
            }
            else
            {
                @Body
            }
        </MudContainer>
    </MudMainContent>

    <!-- Footer fosc, igual que la capçalera -->
    <MudAppBar Bottom="true" Elevation="0" Dense="true" Style="@($"background:{Brand.ColorAppBar}")">
        <MudSpacer />
        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,.6)">
            <strong style="color:rgba(255,255,255,.85)">@Brand.Organitzacio</strong>
            &nbsp;|&nbsp;
            @Brand.Nom © @DateTime.Now.Year
            &nbsp;·&nbsp;
            <span style="color:rgba(255,255,255,.45);font-size:.7rem">v@(AppVersion.Current)</span>
        </MudText>
        <MudSpacer />
    </MudAppBar>
</MudLayout>

@code {
    private bool   _sessionChecked = false;
    private bool   _darkMode       = false;
    private string _primaryColor   = "#CC0000"; // sobreescrit a OnInitialized

    private (string Name, string Hex)[] _colorOptions = []; // inicialitzat a OnInitialized

    private string LogoHref => UserState.IsStudent   ? "/alumne/dashboard"
                             : UserState.IsProfessor ? "/professor/dashboard"
                             : "/";

    protected override void OnInitialized()
    {
        _primaryColor = Brand.ColorPrimary;
        _colorOptions =
        [
            ("Per defecte",  Brand.ColorPrimary),
            ("Blau",         "#1d4ed8"),
            ("Verd",         "#15803d"),
            ("Taronja",      "#ea580c"),
            ("Violeta",      "#7c3aed"),
            ("Gris",         "#475569"),
        ];
        _theme = BuildTheme(Brand.ColorPrimary, Brand.ColorAppBar);
        UserState.OnSessionExpired += HandleSessionExpired;
    }

    public void Dispose()
    {
        UserState.OnSessionExpired -= HandleSessionExpired;
    }

    private async void HandleSessionExpired()
    {
        await InvokeAsync(async () =>
        {
            try { await LocalStorage.DeleteAsync("entornexamen_session"); } catch { }
            Nav.NavigateTo("/", forceLoad: false);
        });
    }

    /// <summary>Decoda el payload del JWT (sense verificar la signatura) i comprova l'expiració.</summary>
    private static bool IsTokenExpired(string token)
    {
        try
        {
            var parts = token.Split('.');
            if (parts.Length != 3) return true;
            var payload = parts[1];
            var padded  = payload + new string('=', (4 - payload.Length % 4) % 4);
            var json    = System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(padded));
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("exp", out var exp))
                return DateTimeOffset.FromUnixTimeSeconds(exp.GetInt64()) <= DateTimeOffset.UtcNow;
            return false;
        }
        catch { return true; }
    }

    private MudTheme _theme = new(); // sobreescrit a OnInitialized via BuildTheme

    private static MudTheme BuildTheme(string primary, string appbar)
    {
        var primaryDark = DarkenHex(primary, 0.15);
        var appbarDark  = DarkenHex(appbar,  0.15);
        return new MudTheme
        {
            PaletteLight = new PaletteLight
            {
                Primary          = primary,
                PrimaryDarken    = primaryDark,
                Secondary        = appbar,
                SecondaryDarken  = appbarDark,
                AppbarBackground = appbar,
                Background       = "#e2e8f0",
                Surface          = "#ffffff",
                DrawerBackground = appbar,
            },
            PaletteDark = new PaletteDark
            {
                Primary          = primary,
                PrimaryDarken    = primaryDark,
                Secondary        = "#94a3b8",
                SecondaryDarken  = "#64748b",
                AppbarBackground = appbarDark,
                Background       = "#020617",
                BackgroundGray   = "#0f172a",
                Surface          = "#1e293b",
                DrawerBackground = appbarDark,
                TextPrimary      = "#f1f5f9",
                TextSecondary    = "#94a3b8",
                ActionDefault    = "#94a3b8",
                LinesDefault     = "rgba(255,255,255,0.08)",
                TableLines       = "rgba(255,255,255,0.08)",
                Divider          = "rgba(255,255,255,0.08)",
            }
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            if (!UserState.IsLoggedIn)
            {
                var stored = await LocalStorage.GetAsync<LoginResponse>("entornexamen_session");
                if (stored.Success && stored.Value is not null)
                {
                    if (IsTokenExpired(stored.Value.Token))
                        await LocalStorage.DeleteAsync("entornexamen_session"); // token caducat → neteja
                    else
                        UserState.SetLogin(stored.Value);
                }
            }
        }
        catch { /* clau DataProtection caducada o dades invàlides → ignora */ }

        try
        {
            var dm = await LocalStorage.GetAsync<bool>("entornexamen_darkmode");
            if (dm.Success) _darkMode = dm.Value;
        }
        catch { }

        try
        {
            var col = await LocalStorage.GetAsync<string>("entornexamen_color");
            if (col.Success && !string.IsNullOrWhiteSpace(col.Value))
                _primaryColor = col.Value;
        }
        catch { }

        ApplyColor(_primaryColor);

        _sessionChecked = true;
        StateHasChanged();
    }

    private async Task ToggleDarkMode()
    {
        _darkMode = !_darkMode;
        await LocalStorage.SetAsync("entornexamen_darkmode", _darkMode);
    }

    private async Task ChangeColorAsync(string hex)
    {
        _primaryColor = hex;
        ApplyColor(hex);
        await LocalStorage.SetAsync("entornexamen_color", hex);
    }

    private void ApplyColor(string hex)
    {
        _theme = BuildTheme(hex, Brand.ColorAppBar);
    }

    private static string DarkenHex(string hex, double amount)
    {
        try
        {
            hex = hex.TrimStart('#');
            var r = Convert.ToInt32(hex[..2], 16);
            var g = Convert.ToInt32(hex[2..4], 16);
            var b = Convert.ToInt32(hex[4..6], 16);
            r = (int)(r * (1 - amount));
            g = (int)(g * (1 - amount));
            b = (int)(b * (1 - amount));
            return $"#{r:X2}{g:X2}{b:X2}";
        }
        catch { return hex; }
    }

    private async Task Logout()
    {
        try { await LocalStorage.DeleteAsync("entornexamen_session"); } catch { }
        UserState.Logout();
        Nav.NavigateTo("/", forceLoad: false);
    }
}
