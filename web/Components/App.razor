@using static Microsoft.AspNetCore.Components.Web.RenderMode
<!DOCTYPE html>
<html lang="ca">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>@Brand.Nom</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="@Brand.ColorAppBar" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link href="/css/site.css" rel="stylesheet" />
    <style>
        :root {
            --primary:    @Brand.ColorPrimary;
            --primary-dk: @Brand.ColorPrimaryDark;
            --appbar:     @Brand.ColorAppBar;
            --appbar-dk:  @Brand.ColorAppBarDark;
            --bg-image:   @Brand.BgImageCssValue;
        }
    </style>
    <HeadContent />
</head>
<body>
    <Routes @rendermode="@(new InteractiveServerRenderMode(prerender: false))" />
    <script src="_framework/blazor.web.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="/js/app.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
    <script src="/js/charts.js"></script>
    <script>window.__entornClientIp='@_clientIp';</script>
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/service-worker.js');
        }
    </script>
</body>
</html>

@code {
    // App.razor s'executa en el thread HTTP inicial → llegim HttpContext aquí.
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    [Inject] private EntornExamen.Web.Services.BrandConfig       Brand        { get; set; } = default!;
    [Inject] private EntornExamen.Web.Services.ExamenCircuitState CircuitState { get; set; } = default!;

    // Emmagatzemat aquí per injectar-lo com a variable JS (window.__entornClientIp).
    // El circuit Blazor crea un DI scope diferent del de la petició HTTP, de manera que
    // CircuitState.ClientIp escrit aquí no és llegit per Portal.razor. La variable JS
    // és l'únic canal que travessa el boundary entre els dos scopes.
    private string _clientIp = "";

    protected override void OnInitialized()
    {
        if (HttpContext is not null)
        {
            var ip = HttpContext.Request.Headers["X-Real-IP"].FirstOrDefault()
                  ?? HttpContext.Request.Headers["X-Forwarded-For"].FirstOrDefault()
                         ?.Split(',')[0].Trim()
                  ?? HttpContext.Connection.RemoteIpAddress?.ToString()
                  ?? "";

            if (System.Net.IPAddress.TryParse(ip, out var addr) && addr.IsIPv4MappedToIPv6)
                ip = addr.MapToIPv4().ToString();

            _clientIp = ip;
        }
    }
}
