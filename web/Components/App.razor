@using static Microsoft.AspNetCore.Components.Web.RenderMode
@using System.Globalization
@using Microsoft.AspNetCore.Localization
<!DOCTYPE html>
<html lang="ca">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>Entorn d'Examens</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#1e293b" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link href="/css/site.css" rel="stylesheet" />
    <HeadContent />
</head>
<body>
    <Routes @rendermode="@(new InteractiveServerRenderMode(prerender: false))" />
    <script src="_framework/blazor.web.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="/js/app.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
    <script src="/js/charts.js"></script>
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/service-worker.js');
        }
    </script>
</body>
</html>

@code {
    // App.razor s'executa com a SSR (thread HTTP) → llegim la cultura establerta
    // per RequestLocalizationMiddleware i la fixem com a DefaultThreadCurrentCulture
    // perquè els threads del circuit Blazor Server l'heretin.
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    protected override void OnInitialized()
    {
        if (HttpContext is not null)
        {
            var feature = HttpContext.Features.Get<IRequestCultureFeature>();
            if (feature is not null)
            {
                CultureInfo.DefaultThreadCurrentCulture   = feature.RequestCulture.Culture;
                CultureInfo.DefaultThreadCurrentUICulture = feature.RequestCulture.UICulture;
            }
        }
    }
}
