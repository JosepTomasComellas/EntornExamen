@page "/admin/importar-epss"
@rendermode InteractiveServer
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResources> Loc

<PageTitle>@Loc["Epss_Title"] – Entorn d'Examens</PageTitle>
@if (!UserState.IsAdmin) { Nav.NavigateTo("/"); return; }

<!-- Capçalera -->
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Wrap="Wrap.Wrap">
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
               Href="/professor/dashboard"
               Variant="Variant.Text" Color="Color.Default">
        @Loc["Nav_Dashboard"]
    </MudButton>
    <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
    <MudIcon Icon="@Icons.Material.Filled.Upload" Color="Color.Primary" Class="mr-1" />
    <MudText Typo="Typo.h5" Style="font-weight:700">@Loc["Epss_Title"]</MudText>
</MudStack>

<MudGrid Spacing="4">

    <!-- ── Importar alumnes XLS ─────────────────────────────────────────── -->
    <MudItem xs="12" md="6">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderAvatar>
                    <MudAvatar Color="Color.Primary">
                        <MudIcon Icon="@Icons.Material.Filled.TableChart" />
                    </MudAvatar>
                </CardHeaderAvatar>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">@Loc["Epss_SubtitleAlumnes"]</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@Loc["Epss_AlumnesDesc"]</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudFileUpload T="IBrowserFile" FilesChanged="OnXlsSeleccionat"
                               Accept=".xls,.xlsx">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.AttachFile">
                            @Loc["Epss_SeleccionaFitxer"]
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>
                @if (_xlsFitxer is not null)
                {
                    <MudText Typo="Typo.body2" Class="mt-2">
                        <MudIcon Icon="@Icons.Material.Filled.InsertDriveFile"
                                 Size="Size.Small" Class="mr-1" />
                        @_xlsFitxer.Name
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-1">
                            (@(((_xlsFitxer.Size / 1024.0)).ToString("0.0")) KB)
                        </MudText>
                    </MudText>
                }

                @if (_resultAlumnes is not null)
                {
                    <MudAlert Severity="Severity.Success" Dense="true" Class="mt-3">
                        @Loc["Epss_ResultatAlumnes",
                             _resultAlumnes.Importats,
                             _resultAlumnes.Actualitzats,
                             _resultAlumnes.Saltats]
                    </MudAlert>
                    @if (_resultAlumnes.Errors.Count > 0)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                            <strong>@Loc["Epss_Errors"]</strong>
                            <ul style="margin:4px 0 0 16px;padding:0">
                                @foreach (var e in _resultAlumnes.Errors)
                                {
                                    <li><MudText Typo="Typo.caption">@e</MudText></li>
                                }
                            </ul>
                        </MudAlert>
                    }
                }
                @if (_errorAlumnes is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mt-3">@_errorAlumnes</MudAlert>
                }
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Upload"
                           OnClick="ImportarAlumnes"
                           Disabled="@(_xlsFitxer is null || _carregantAlumnes)">
                    @if (_carregantAlumnes)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    @Loc["Epss_Importar"]
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    <!-- ── Importar fotos ZIP ────────────────────────────────────────────── -->
    <MudItem xs="12" md="6">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderAvatar>
                    <MudAvatar Color="Color.Secondary">
                        <MudIcon Icon="@Icons.Material.Filled.PhotoLibrary" />
                    </MudAvatar>
                </CardHeaderAvatar>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">@Loc["Epss_SubtitleFotos"]</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@Loc["Epss_FotosDesc"]</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                    <strong>@Loc["Epss_ComObtenir"]</strong>
                    <ol style="margin:4px 0 0 16px;padding:0">
                        <li><MudText Typo="Typo.caption">@Loc["Epss_Pas1"]</MudText></li>
                        <li><MudText Typo="Typo.caption">@Loc["Epss_Pas2"]</MudText></li>
                        <li><MudText Typo="Typo.caption">@Loc["Epss_Pas3"]</MudText></li>
                    </ol>
                </MudAlert>

                <MudFileUpload T="IBrowserFile" FilesChanged="OnZipSeleccionat"
                               Accept=".zip">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Filled.FolderZip">
                            @Loc["Epss_SeleccionaZip"]
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>
                @if (_zipFitxer is not null)
                {
                    <MudText Typo="Typo.body2" Class="mt-2">
                        <MudIcon Icon="@Icons.Material.Filled.FolderZip"
                                 Size="Size.Small" Class="mr-1" />
                        @_zipFitxer.Name
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-1">
                            (@((_zipFitxer.Size / 1024.0 / 1024.0).ToString("0.0")) MB)
                        </MudText>
                    </MudText>
                }

                @if (_resultFotos is not null)
                {
                    <MudAlert Severity="Severity.Success" Dense="true" Class="mt-3">
                        @Loc["Epss_ResultatFotos", _resultFotos.Importades]
                    </MudAlert>
                    @if (_resultFotos.NoTrobades.Count > 0)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                            <strong>@Loc["Epss_NoTrobades"]</strong>
                            <MudText Typo="Typo.caption">
                                @string.Join(", ", _resultFotos.NoTrobades)
                            </MudText>
                        </MudAlert>
                    }
                    @if (_resultFotos.Errors.Count > 0)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                            <strong>@Loc["Epss_Errors"]</strong>
                            <ul style="margin:4px 0 0 16px;padding:0">
                                @foreach (var e in _resultFotos.Errors)
                                {
                                    <li><MudText Typo="Typo.caption">@e</MudText></li>
                                }
                            </ul>
                        </MudAlert>
                    }
                }
                @if (_errorFotos is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mt-3">@_errorFotos</MudAlert>
                }
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.Upload"
                           OnClick="ImportarFotos"
                           Disabled="@(_zipFitxer is null || _carregantFotos)">
                    @if (_carregantFotos)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    @Loc["Epss_Importar"]
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

</MudGrid>

@code {
    private IBrowserFile? _xlsFitxer;
    private IBrowserFile? _zipFitxer;
    private bool _carregantAlumnes;
    private bool _carregantFotos;

    private ImportacioAlumnesResult? _resultAlumnes;
    private ImportacioFotosResult?   _resultFotos;
    private string? _errorAlumnes;
    private string? _errorFotos;

    protected override void OnInitialized()
    {
        if (!UserState.IsAdmin) return;
        Api.SetToken(UserState.Token!);
    }

    private void OnXlsSeleccionat(IBrowserFile file)
    {
        _xlsFitxer    = file;
        _resultAlumnes = null;
        _errorAlumnes  = null;
    }

    private void OnZipSeleccionat(IBrowserFile file)
    {
        _zipFitxer  = file;
        _resultFotos = null;
        _errorFotos  = null;
    }

    private async Task ImportarAlumnes()
    {
        if (_xlsFitxer is null) return;
        _carregantAlumnes = true;
        _resultAlumnes    = null;
        _errorAlumnes     = null;

        try
        {
            using var content = new MultipartFormDataContent();
            using var stream  = _xlsFitxer.OpenReadStream(10 * 1024 * 1024);
            content.Add(new StreamContent(stream), "fitxer", _xlsFitxer.Name);
            var (result, error) = await Api.ImportarAlumnesXlsAsync(content);
            if (error is not null) _errorAlumnes = error;
            else
            {
                _resultAlumnes = result;
                Snackbar.Add(Loc["Epss_ResultatAlumnes",
                    result!.Importats, result.Actualitzats, result.Saltats].Value,
                    Severity.Success);
            }
        }
        catch (Exception ex) { _errorAlumnes = ex.Message; }
        finally { _carregantAlumnes = false; }
    }

    private async Task ImportarFotos()
    {
        if (_zipFitxer is null) return;
        _carregantFotos = true;
        _resultFotos    = null;
        _errorFotos     = null;

        try
        {
            using var content = new MultipartFormDataContent();
            using var stream  = _zipFitxer.OpenReadStream(100 * 1024 * 1024);
            content.Add(new StreamContent(stream), "zip", _zipFitxer.Name);
            var (result, error) = await Api.ImportarFotosExamenAsync(content);
            if (error is not null) _errorFotos = error;
            else
            {
                _resultFotos = result;
                Snackbar.Add(Loc["Epss_ResultatFotos", result!.Importades].Value, Severity.Success);
            }
        }
        catch (Exception ex) { _errorFotos = ex.Message; }
        finally { _carregantFotos = false; }
    }
}
