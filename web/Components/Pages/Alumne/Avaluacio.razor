@page "/alumne/avaluacio/{ActivityId:int}"
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResources> Loc

<PageTitle>Avaluació – Entorn d'Examens</PageTitle>
@if (!UserState.IsStudent) { Nav.NavigateTo("/"); return; }

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_form is null)
{
    <MudAlert Severity="Severity.Error" Class="mb-3">@Loc["Eval_NotAvailable"]</MudAlert>
    <MudButton Href="/alumne/dashboard">@Loc["Eval_BackToBoard"]</MudButton>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2" Wrap="Wrap.Wrap">
        <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Href="/alumne/dashboard"
                   Variant="Variant.Text">
            @Loc["Eval_Back"]
        </MudButton>
        <MudStack Spacing="0" Style="flex:1;min-width:0">
            <MudText Typo="Typo.h6" Style="font-weight:700">@_form.Activity.Name</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Eval_Group", _form.Group.Name]</MudText>
        </MudStack>
    </MudStack>

    @if (_form.Activity.Description is not null)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
            @_form.Activity.Description
        </MudText>
    }

    <div class="progress-sticky">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudProgressLinear Value="_pctProg" Color="@(_totProg ? Color.Success : Color.Primary)"
                               Rounded="true" Style="flex:1;height:8px" />
            <MudText Typo="Typo.caption" Color="@(_totProg ? Color.Success : Color.Secondary)"
                     Style="white-space:nowrap">
                @Loc["Eval_CriteriaProgress", _completats, _totalCriteris]
            </MudText>
        </MudStack>
    </div>

    @foreach (var entry in _form.Entries)
    {
        var isSelf = entry.IsSelf;
        <MudPaper Elevation="2" Class="pa-4 mb-4"
                  Style="@(isSelf ? "border-left:4px solid var(--mud-palette-primary)" : "border-left:4px solid var(--mud-palette-grey-400)")">

            <!-- Capçalera de la persona avaluada -->
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-4"
                      Wrap="Wrap.Wrap">
                <MudAvatar Color="@(isSelf ? Color.Primary : Color.Secondary)"
                           Variant="Variant.Filled" Size="Size.Small" Style="flex-shrink:0">
                    @entry.StudentName[0]
                </MudAvatar>
                <MudText Typo="Typo.subtitle1" Style="font-weight:600;flex:1">
                    @entry.StudentName
                </MudText>
                <MudChip T="string" Size="Size.Small"
                         Color="@(isSelf ? Color.Primary : Color.Secondary)">
                    @(isSelf ? Loc["Eval_SelfEval"].Value : Loc["Eval_CoEval"].Value)
                </MudChip>
            </MudStack>

            <!-- Criteris amb MudRating (5 estrelles × 2 = escala 1-10) -->
            @foreach (var criteri in _criteria)
            {
                var key     = criteri.Key;
                var current = _scores.TryGetValue((entry.StudentId, key), out var v) ? v : 0.0;
                var stars   = StarsFromScore(current);

                <MudStack Class="mb-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1"
                              Wrap="Wrap.Wrap">
                        <MudText Typo="Typo.subtitle2" Style="flex:1;min-width:120px">
                            @criteri.Label
                        </MudText>
                        @if (current > 0)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                                     Variant="Variant.Filled"
                                     Style="font-weight:700;min-width:62px;justify-content:center">
                                @ScoreLabel(stars)
                            </MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                     Variant="Variant.Outlined"
                                     Style="min-width:52px;justify-content:center">
                                –
                            </MudChip>
                        }
                    </MudStack>

                    <!-- 5 estrelles: 1★=E(1), 2★=D(3.5), 3★=C(5), 4★=B(7.5), 5★=A(10) -->
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudRating SelectedValue="stars"
                                   SelectedValueChanged="val => SetScore(entry.StudentId, key, val)"
                                   MaxValue="5"
                                   Color="Color.Warning"
                                   Size="Size.Large"
                                   HoveredValueChanged="val => OnHover(entry.StudentId, key, val ?? 0)" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary"
                                 Style="white-space:nowrap;font-size:.75rem">
                            @ScaleHint(entry.StudentId, key, stars)
                        </MudText>
                    </MudStack>
                </MudStack>
            }

            <!-- Comentari -->
            <MudTextField @bind-Value="_comments[entry.StudentId]"
                          Label="@Loc["Eval_Comment"]" Variant="Variant.Outlined"
                          Lines="2" MaxLength="500" />
        </MudPaper>
    }

    <MudStack Row="true" Class="mt-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                   FullWidth="true"
                   OnClick="SaveAsync" Disabled="_saving">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @Loc["Eval_Save"]
        </MudButton>
    </MudStack>

}

@code {
    [Parameter] public int ActivityId { get; set; }

    private EvaluationFormDto?   _form     = null;
    private List<CriteriaDto>    _criteria = [];
    private bool _loading = true;
    private bool _saving  = false;

    // Puntuació per (studentId, criteriaKey): E=1, D=3.5, C=5, B=7.5, A=10
    private Dictionary<(int, string), double> _scores   = new();

    // Progrés del formulari
    private int    _totalCriteris => _form is null ? 0 : _form.Entries.Count * _criteria.Count;
    private int    _completats    => _scores.Count(kv => kv.Value > 0);
    private double _pctProg       => _totalCriteris > 0 ? (double)_completats / _totalCriteris * 100 : 0;
    private bool   _totProg       => _completats >= _totalCriteris && _totalCriteris > 0;
    private Dictionary<int, string>           _comments = new();
    // Valor hovered per mostrar l'hint en temps real
    private Dictionary<(int, string), int>    _hovered  = new();

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsStudent) return;
        Api.SetToken(UserState.Token!);
        _form     = await Api.GetEvaluationFormAsync(ActivityId);
        _criteria = await Api.GetCriteriaAsync() ?? [];

        if (_form is not null)
        {
            foreach (var entry in _form.Entries)
            {
                _comments[entry.StudentId] = entry.Comment ?? "";
                foreach (var c in _criteria)
                    _scores[(entry.StudentId, c.Key)] =
                        entry.Scores.TryGetValue(c.Key, out var sv) ? sv : 0.0;
            }
        }
        _loading = false;
    }

    private static double ScoreFromStars(int stars) => stars switch
    {
        1 => 1.0,
        2 => 3.5,
        3 => 5.0,
        4 => 7.5,
        5 => 10.0,
        _ => 0.0
    };

    private static int StarsFromScore(double score) => score switch
    {
        > 0 and <= 1.0 => 1,
        > 1.0 and <= 3.5 => 2,
        > 3.5 and <= 5.0 => 3,
        > 5.0 and <= 7.5 => 4,
        > 7.5 => 5,
        _ => 0
    };

    private static string ScoreLabel(int stars) => stars switch
    {
        1 => "E", 2 => "D", 3 => "C", 4 => "B", 5 => "A", _ => "–"
    };

    private void SetScore(int studentId, string key, int stars)
    {
        var current  = _scores.TryGetValue((studentId, key), out var v) ? v : 0.0;
        var newScore = ScoreFromStars(stars);
        // Clic sobre la mateixa estrella → desselecciona
        _scores[(studentId, key)] = (current == newScore) ? 0.0 : newScore;
        _hovered.Remove((studentId, key));
    }

    private void OnHover(int studentId, string key, int stars)
    {
        if (stars > 0)
            _hovered[(studentId, key)] = stars;
        else
            _hovered.Remove((studentId, key));
    }

    private string ScaleHint(int studentId, string key, int currentStars)
    {
        var stars = _hovered.TryGetValue((studentId, key), out var h) ? h : currentStars;
        return stars switch
        {
            1 => "E", 2 => "D", 3 => "C", 4 => "B", 5 => "A", _ => ""
        };
    }

    private async Task SaveAsync()
    {
        var missing = new List<string>();
        if (_form is not null)
        {
            foreach (var entry in _form.Entries)
                foreach (var c in _criteria)
                    if (!_scores.TryGetValue((entry.StudentId, c.Key), out var v) || v <= 0)
                        missing.Add($"{entry.StudentName} → {c.Label}");
        }
        if (missing.Any())
        {
            Snackbar.Add(
                Loc["Eval_Missing", $"{string.Join(", ", missing.Take(3))}{(missing.Count > 3 ? "..." : "")}"].Value,
                Severity.Warning);
        }

        _saving = true;
        Api.SetToken(UserState.Token!);
        var request = new SaveEvaluationsRequest(
            _form!.Entries.Select(entry => new EvaluationEntryRequest(
                entry.StudentId,
                _criteria.ToDictionary(c => c.Key,
                    c => _scores.TryGetValue((entry.StudentId, c.Key), out var sv) ? sv : 0.0),
                string.IsNullOrWhiteSpace(_comments[entry.StudentId])
                    ? null : _comments[entry.StudentId].Trim()
            )).ToList());

        var ok = await Api.SaveEvaluationsAsync(ActivityId, request);
        _saving = false;

        if (ok)
        {
            Snackbar.Add(Loc["Eval_Saved"].Value, Severity.Success);
            Nav.NavigateTo("/alumne/dashboard");
        }
        else
            Snackbar.Add(Loc["Eval_SaveError"].Value, Severity.Error);
    }
}
