@page "/"
@inject UserStateService UserState
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> Loc

<PageTitle>Entorn d'Examens</PageTitle>

@if (UserState.IsLoggedIn)
{
    if (UserState.IsProfessor) Nav.NavigateTo("/professor/dashboard");
    else Nav.NavigateTo("/examen");
}

<div style="min-height:80vh;display:flex;align-items:center;justify-content:center;padding:1rem 0">
    <MudContainer MaxWidth="MaxWidth.Small">

        <!-- Targeta principal -->
        <MudPaper Elevation="6" Style="overflow:hidden;border-radius:16px">

            <!-- Capçalera fosca amb logo -->
            <div style="background:linear-gradient(135deg,#1e293b 0%,#0f172a 100%);padding:2.5rem 2rem;text-align:center">
                <MudImage Src="/images/logo2.png" Height="56"
                          Style="display:inline-block;margin-bottom:.75rem;filter:drop-shadow(0 2px 8px rgba(0,0,0,.4))" />
                <MudText Typo="Typo.h6" Style="color:white;font-weight:700;margin-bottom:.25rem">
                    @Loc["Home_Title"]
                </MudText>
                <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,.55)">
                    @Loc["Home_Subtitle"]
                </MudText>
            </div>

            <!-- Botons d'accés -->
            <div style="padding:2rem">
                <MudStack Spacing="3">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               Size="Size.Large" FullWidth="true"
                               Href="/auth/login-professor"
                               StartIcon="@Icons.Material.Filled.School"
                               Style="font-size:1rem;padding:.75rem 1rem">
                        @Loc["Home_TeacherAccess"]
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               Size="Size.Large" FullWidth="true"
                               Href="/auth/login-alumne"
                               StartIcon="@Icons.Material.Filled.Person"
                               Style="font-size:1rem;padding:.75rem 1rem">
                        @Loc["Home_StudentAccess"]
                    </MudButton>
                </MudStack>
            </div>

            <!-- Característiques -->
            <MudDivider />
            <div style="padding:1.5rem 2rem 1rem">
                <MudGrid Spacing="2" Justify="Justify.Center">
                    <MudItem xs="4" Style="text-align:center">
                        <MudIcon Icon="@Icons.Material.Filled.Monitor" Color="Color.Primary" Size="Size.Medium" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display:block;margin-top:.25rem">
                            @Loc["Home_Feature1"]
                        </MudText>
                    </MudItem>
                    <MudItem xs="4" Style="text-align:center">
                        <MudIcon Icon="@Icons.Material.Filled.Wifi" Color="Color.Info" Size="Size.Medium" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display:block;margin-top:.25rem">
                            @Loc["Home_Feature2"]
                        </MudText>
                    </MudItem>
                    <MudItem xs="4" Style="text-align:center">
                        <MudIcon Icon="@Icons.Material.Filled.Campaign" Color="Color.Warning" Size="Size.Medium" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display:block;margin-top:.25rem">
                            @Loc["Home_Feature3"]
                        </MudText>
                    </MudItem>
                </MudGrid>
            </div>

            <!-- Peu de targeta amb versió -->
            <div style="padding:.5rem 2rem 1rem;text-align:center">
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @Loc["Home_Footer"]
                    &nbsp;·&nbsp; <span style="opacity:.6">v@(AppVersion.Current)</span>
                </MudText>
            </div>

        </MudPaper>

    </MudContainer>
</div>
