@page "/auth/login-professor"
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav
@inject ProtectedLocalStorage LocalStorage
@inject IStringLocalizer<SharedResources> Loc

<PageTitle>Accés Professor – Entorn d'Examens</PageTitle>

<div style="min-height:80vh;display:flex;align-items:center;justify-content:center">
    <MudContainer MaxWidth="MaxWidth.ExtraSmall">
        <MudPaper Elevation="4" Style="overflow:hidden;border-radius:12px">

            <div style="background:#1e293b;padding:1.5rem 2rem;display:flex;align-items:center;gap:1rem">
                <MudIcon Icon="@Icons.Material.Filled.School"
                         Style="color:rgba(255,255,255,.9);font-size:2rem;flex-shrink:0" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6" Style="color:white;font-weight:700;line-height:1.2">
                        @Loc["Login_Teacher_Title"]
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,.55)">
                        @Loc["Login_Subtitle"]
                    </MudText>
                </MudStack>
            </div>

            <div style="padding:1.75rem 2rem">
                @if (_error is not null)
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
                }

                <MudTextField @bind-Value="_email" Label="@Loc["Login_Email"]"
                              Variant="Variant.Outlined" Class="mb-3"
                              Immediate="true" InputType="InputType.Email"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Email"
                              @onkeydown="OnKeyDown" />
                <MudTextField @bind-Value="_password" Label="@Loc["Login_Password"]"
                              Variant="Variant.Outlined" Class="mb-5"
                              Immediate="true"
                              InputType="@_pwdType"
                              Adornment="Adornment.End" AdornmentIcon="@_pwdIcon"
                              OnAdornmentClick="TogglePassword"
                              @onkeydown="OnKeyDown" />

                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           FullWidth="true" Size="Size.Large"
                           OnClick="Login" Disabled="_loading">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    @Loc["Login_Submit"]
                </MudButton>

                <MudLink Href="/auth/reset-contrasenya" Class="d-block text-center mt-3"
                         Color="Color.Default" Typo="Typo.caption">
                    @Loc["Login_ForgotPassword"]
                </MudLink>
                <MudLink Href="/" Class="d-block text-center mt-2" Color="Color.Secondary">
                    @Loc["Login_Back"]
                </MudLink>
            </div>

        </MudPaper>
    </MudContainer>
</div>

@code {
    private string _email    = "";
    private string _password = "";
    private string? _error;
    private bool _loading;
    private bool _showPwd;
    private InputType _pwdType => _showPwd ? InputType.Text     : InputType.Password;
    private string   _pwdIcon  => _showPwd ? Icons.Material.Filled.VisibilityOff
                                           : Icons.Material.Filled.Visibility;

    protected override void OnInitialized()
    {
        if (UserState.IsProfessor)
            Nav.NavigateTo("/professor/dashboard");
    }

    private void TogglePassword() => _showPwd = !_showPwd;

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Login();
    }

    private async Task Login()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            _error = Loc["Login_Error_EmptyFields"]; return;
        }
        _loading = true; _error = null;
        var result = await Api.LoginProfessorAsync(_email.Trim(), _password);
        _loading = false;
        if (result is null) { _error = Loc["Login_Error_InvalidCredentials"]; return; }
        await LocalStorage.SetAsync("autoco_session", result);
        UserState.SetLogin(result);
        Nav.NavigateTo("/professor/dashboard");
    }
}
