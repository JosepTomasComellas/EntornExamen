@page "/examen"
@rendermode InteractiveServer
@inject ApiClient Api
@inject ExamenNotificationService ExamenNotif
@inject IStringLocalizer<SharedResources> Loc
@implements IDisposable

<PageTitle>@Loc["ExamenPortal_Title"] — Salesians de Sarrià</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">

    @if (_fase == Fase.Email)
    {
        <MudCard Elevation="6" Class="pa-6">
            <MudCardContent>
                <MudStack Spacing="4" AlignItems="AlignItems.Center">
                    <MudImage Src="/images/logo2.png" Height="60" />
                    <MudText Typo="Typo.h5" Align="Align.Center">
                        <strong>@Loc["ExamenPortal_Title"]</strong>
                    </MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                        @Loc["ExamenPortal_Subtitle"]
                    </MudText>

                    <MudDivider />

                    <MudText Typo="Typo.body1" Align="Align.Center">
                        @Loc["ExamenPortal_EmailPrompt"]
                    </MudText>

                    <MudTextField @bind-Value="_email"
                                  Label="@Loc["ExamenPortal_EmailLabel"]"
                                  InputType="InputType.Email"
                                  FullWidth="true"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Email"
                                  OnKeyDown="OnEmailKeyDown" />

                    @if (_suggeriment is not null)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true"
                                  OnClick="@(() => { _email = _suggeriment; _suggeriment = null; })"
                                  Style="cursor:pointer;width:100%">
                            @Loc["ExamenPortal_SuggestEmail", _suggeriment]
                        </MudAlert>
                    }

                    @if (_errorEmail is not null)
                    {
                        <MudAlert Severity="Severity.Error" Dense="true">@_errorEmail</MudAlert>
                    }

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                               Size="Size.Large" OnClick="ValidarEmail"
                               Disabled="_carregant"
                               StartIcon="@Icons.Material.Filled.Login">
                        @if (_carregant)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        }
                        else
                        {
                            <span>@Loc["ExamenPortal_Continue"]</span>
                        }
                    </MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>
    }

    @if (_fase == Fase.ConfirmacioMac)
    {
        <MudCard Elevation="6" Class="pa-6">
            <MudCardContent>
                <MudStack Spacing="4" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.DevicesOther"
                             Color="Color.Warning" Size="Size.Large"
                             Style="font-size:4rem" />
                    <MudText Typo="Typo.h6" Align="Align.Center">
                        @Loc["ExamenPortal_NewDevice"]
                    </MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center">
                        @Loc["ExamenPortal_NewDeviceInfo"]
                    </MudText>
                    <MudChip T="string" Color="Color.Secondary" Size="Size.Medium">
                        @_macObtinguda
                    </MudChip>

                    @if (_errorCheckin is not null)
                    {
                        <MudAlert Severity="Severity.Error" Dense="true">@_errorCheckin</MudAlert>
                    }

                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Outlined" Color="Color.Default"
                                   OnClick="@(() => { _fase = Fase.Email; _errorCheckin = null; })">
                            @Loc["Action_Cancel"]
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Warning"
                                   OnClick="FerCheckin" Disabled="_carregant">
                            @if (_carregant)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                            }
                            else
                            {
                                <span>@Loc["ExamenPortal_ConfirmReg"]</span>
                            }
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudCardContent>
        </MudCard>
    }

    @if (_fase == Fase.Connectat && _checkinResp is not null)
    {
        <MudCard Elevation="6" Class="pa-4">
            <MudCardContent>
                <MudStack Spacing="3" AlignItems="AlignItems.Center">

                    @if (_checkinResp.Alumne.FotoUrl is not null)
                    {
                        <MudAvatar Style="width:96px;height:96px">
                            <MudImage Src="@_checkinResp.Alumne.FotoUrl"
                                      Style="width:96px;height:96px;object-fit:cover" />
                        </MudAvatar>
                    }
                    else
                    {
                        <MudAvatar Color="Color.Primary" Style="width:96px;height:96px;font-size:2.5rem">
                            @((_checkinResp.Alumne.Nom?[..1] ?? "") + (_checkinResp.Alumne.Cognoms?[..1] ?? ""))
                        </MudAvatar>
                    }

                    <MudText Typo="Typo.h5" Align="Align.Center">
                        @_checkinResp.Alumne.Nom @_checkinResp.Alumne.Cognoms
                    </MudText>
                    <MudChip T="string" Color="Color.Secondary" Size="Size.Small">
                        @_checkinResp.Alumne.Classe
                    </MudChip>

                    <MudDivider />

                    @if (!string.IsNullOrWhiteSpace(_checkinResp.Sessio.Titol))
                    {
                        <MudText Typo="Typo.subtitle1" Align="Align.Center">
                            <strong>@_checkinResp.Sessio.Titol</strong>
                        </MudText>
                    }
                    @if (!string.IsNullOrWhiteSpace(_checkinResp.Sessio.Descripcio))
                    {
                        <MudText Typo="Typo.body2" Align="Align.Center">
                            @_checkinResp.Sessio.Descripcio
                        </MudText>
                    }

                    <MudDivider />

                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <div style="width:14px;height:14px;border-radius:50%;background:#22c55e;
                                    animation: pulse-green 1.5s infinite"></div>
                        <MudText Typo="Typo.body1" Color="Color.Success">
                            <strong>@Loc["ExamenPortal_Connected"]</strong>
                        </MudText>
                    </MudStack>

                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @Loc["ExamenPortal_LastCheckin",
                             _ultimCheckin.ToLocalTime().ToString("HH:mm:ss"),
                             _segonsRestants]
                    </MudText>

                    <MudProgressLinear
                        Value="@(CheckinInterval > 0 ? (100 - _segonsRestants * 100 / CheckinInterval) : 0)"
                        Color="Color.Success" Rounded="true" Size="Size.Small"
                        Style="width:100%" />
                </MudStack>
            </MudCardContent>
        </MudCard>
    }

</MudContainer>

<!-- Diàleg obligatori del missatge del professor -->
<MudDialog @bind-Visible="_mostrarMissatge">
    <TitleContent>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Campaign" Color="Color.Warning" />
            <MudText Typo="Typo.h6">@Loc["ExamenPortal_TeacherMsg"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
            @_missatgeProfessor
        </MudAlert>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Warning"
                   OnClick="@(() => _mostrarMissatge = false)">
            @Loc["ExamenPortal_ReadMsg"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private enum Fase { Email, ConfirmacioMac, Connectat }

    private int CheckinInterval => _checkinResp?.Sessio.IntervalSegons ?? 30;

    private Fase    _fase = Fase.Email;
    private string  _email        = "";
    private string? _suggeriment;
    private string? _errorEmail;
    private string? _errorCheckin;
    private string  _macObtinguda = "";
    private bool    _carregant;

    private CheckinResponse? _checkinResp;
    private DateTime _ultimCheckin;
    private int      _segonsRestants;
    private System.Threading.Timer? _timer;

    private bool   _mostrarMissatge;
    private string _missatgeProfessor = "";

    private Func<string, object, Task>? _alumneHandler;

    protected override void OnInitialized()
    {
        _macObtinguda = "00:00:00:00:00:00";
    }

    private void OnEmailKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") _ = ValidarEmail();
    }

    private async Task ValidarEmail()
    {
        _errorEmail  = null;
        _suggeriment = null;

        var email = _email.Trim().ToLower();

        if (!email.Contains('@'))
        {
            _suggeriment = $"{email}@sarria.salesians.cat";
            StateHasChanged();
            return;
        }

        await FerCheckin();
    }

    private async Task FerCheckin()
    {
        _carregant    = true;
        _errorCheckin = null;
        StateHasChanged();

        var (resp, error) = await Api.ExamenCheckinAsync(
            new CheckinRequest(_email.Trim(), _macObtinguda));

        _carregant = false;

        if (error is not null)
        {
            _errorEmail   = error;
            _errorCheckin = error;
            _fase = Fase.Email;
        }
        else if (resp is not null)
        {
            _checkinResp    = resp;
            _ultimCheckin   = DateTime.UtcNow;
            _segonsRestants = resp.Sessio.IntervalSegons;
            _fase           = Fase.Connectat;

            if (!string.IsNullOrWhiteSpace(resp.Sessio.MissatgeActiu))
            {
                _missatgeProfessor = resp.Sessio.MissatgeActiu;
                _mostrarMissatge   = true;
            }

            SubscriuNotificacions(resp.Alumne.StudentId);
            IniciaTimer();
        }

        StateHasChanged();
    }

    private void SubscriuNotificacions(int studentId)
    {
        _alumneHandler = async (eventNom, data) =>
        {
            switch (eventNom)
            {
                case "MissatgeProfessor" when data is ExamenEventMissatge msg:
                    _missatgeProfessor = msg.Text;
                    _mostrarMissatge   = true;
                    await InvokeAsync(StateHasChanged);
                    break;
                case "SessioTancadaGlobal":
                    _checkinResp = null;
                    _fase        = Fase.Email;
                    _errorEmail  = Loc["ExamenPortal_SessionEnded"].Value;
                    _timer?.Dispose();
                    _timer = null;
                    await InvokeAsync(StateHasChanged);
                    break;
            }
        };
        ExamenNotif.SubscriuAlumne(studentId, _alumneHandler);
    }

    private void IniciaTimer()
    {
        _timer?.Dispose();
        _segonsRestants = CheckinInterval;

        _timer = new System.Threading.Timer(async _ =>
        {
            _segonsRestants--;
            if (_segonsRestants <= 0)
            {
                _segonsRestants = CheckinInterval;
                if (_checkinResp is not null)
                {
                    var (resp, _) = await Api.ExamenCheckinAsync(
                        new CheckinRequest(_email.Trim(), _macObtinguda));
                    if (resp is not null) _ultimCheckin = DateTime.UtcNow;
                }
            }
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    public void Dispose()
    {
        _timer?.Dispose();
        if (_alumneHandler is not null && _checkinResp is not null)
            ExamenNotif.DesubscriuAlumne(_checkinResp.Alumne.StudentId, _alumneHandler);
    }
}
