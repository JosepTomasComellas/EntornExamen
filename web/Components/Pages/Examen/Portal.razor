@page "/examen"
@rendermode InteractiveServer
@inject ApiClient Api
@inject ExamenNotificationService ExamenNotif
@inject IStringLocalizer<SharedResources> Loc
@inject ExamenCircuitState CircuitState
@inject IJSRuntime JS
@inject IConfiguration Config
@inject EntornExamen.Web.Services.BrandConfig Brand
@implements IDisposable

<PageTitle>@Loc["ExamenPortal_Title"] — @Brand.Nom</PageTitle>

@if (_fase == Fase.Email)
{
    <div style="min-height:80vh;display:flex;align-items:center;justify-content:center">
        <MudContainer MaxWidth="MaxWidth.ExtraSmall">
            <MudPaper Elevation="4" Style="overflow:hidden;border-radius:12px">

                <div style="background:var(--appbar,#1e293b);padding:1.5rem 2rem;display:flex;align-items:center;gap:1rem">
                    <MudIcon Icon="@Icons.Material.Filled.MenuBook"
                             Style="color:rgba(255,255,255,.9);font-size:2rem;flex-shrink:0" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h6" Style="color:white;font-weight:700;line-height:1.2">
                            @Loc["Login_Student_Title"]
                        </MudText>
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,.55)">
                            @Loc["Login_Subtitle"]
                        </MudText>
                    </MudStack>
                </div>

                <div style="padding:1.75rem 2rem">
                    @if (_errorEmail is not null)
                    {
                        <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_errorEmail</MudAlert>
                    }
                    <MudTextField @bind-Value="_email"
                                  Label="@Loc["ExamenPortal_EmailLabel"]"
                                  InputType="InputType.Email"
                                  FullWidth="true"
                                  Variant="Variant.Outlined"
                                  Class="mb-5"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Email"
                                  Immediate="true"
                                  OnKeyDown="OnEmailKeyDown" />

                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               FullWidth="true" Size="Size.Large"
                               OnClick="ValidarEmail" Disabled="_carregant">
                        @if (_carregant)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        else
                        {
                            <span>@Loc["ExamenPortal_Continue"]</span>
                        }
                    </MudButton>

                    <MudLink Href="/" Class="d-block text-center mt-3" Color="Color.Secondary">
                        @Loc["Action_Back"]
                    </MudLink>
                </div>

            </MudPaper>
        </MudContainer>
    </div>
}

@if (_fase == Fase.Connectat && _checkinResp is not null)
{
    <div style="min-height:80vh;display:flex;align-items:center;justify-content:center">
        <MudContainer MaxWidth="MaxWidth.ExtraSmall">
            <MudPaper Elevation="4" Style="overflow:hidden;border-radius:12px">

                <!-- Capçalera amb foto/avatar i nom -->
                <div style="background:var(--appbar,#1e293b);padding:1.5rem 2rem;display:flex;align-items:center;gap:1rem">
                    @if (_checkinResp.Alumne.FotoUrl is not null)
                    {
                        <MudAvatar Style="width:56px;height:56px;flex-shrink:0">
                            <MudImage Src="@_checkinResp.Alumne.FotoUrl"
                                      Style="width:56px;height:56px;object-fit:cover" />
                        </MudAvatar>
                    }
                    else
                    {
                        <MudAvatar Style="width:56px;height:56px;background:#334155;font-size:1.5rem;color:rgba(255,255,255,.9);flex-shrink:0">
                            @(((_checkinResp.Alumne.Nom?.Length > 0 ? _checkinResp.Alumne.Nom[..1] : "") + (_checkinResp.Alumne.Cognoms?.Length > 0 ? _checkinResp.Alumne.Cognoms[..1] : "")).ToUpper())
                        </MudAvatar>
                    }
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h6" Style="color:white;font-weight:700;line-height:1.2">
                            @_checkinResp.Alumne.Nom @_checkinResp.Alumne.Cognoms
                        </MudText>
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,.55)">
                            @_checkinResp.Alumne.Classe
                        </MudText>
                    </MudStack>
                </div>

                <div style="padding:1.5rem 2rem">
                    @if (!string.IsNullOrWhiteSpace(_checkinResp.Sessio.Titol))
                    {
                        <MudText Typo="Typo.subtitle1" Style="font-weight:600" Class="mb-1">
                            @_checkinResp.Sessio.Titol
                        </MudText>
                    }
                    @if (!string.IsNullOrWhiteSpace(_checkinResp.Sessio.Descripcio))
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                            @_checkinResp.Sessio.Descripcio
                        </MudText>
                    }

                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-2">
                        <div style="width:12px;height:12px;border-radius:50%;background:#22c55e;
                                    animation:pulse-green 1.5s infinite;flex-shrink:0"></div>
                        <MudText Typo="Typo.body2" Color="Color.Success" Style="font-weight:600">
                            @Loc["ExamenPortal_Connected"]
                        </MudText>
                    </MudStack>

                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2 d-block">
                        @Loc["ExamenPortal_LastCheckin",
                             _ultimCheckin.ToLocalTime().ToString("HH:mm:ss"),
                             _segonsRestants]
                    </MudText>

                    <MudProgressLinear
                        Value="@(CheckinInterval > 0 ? Math.Clamp(100 - _segonsRestants * 100 / CheckinInterval, 0, 100) : 0)"
                        Color="Color.Success" Rounded="true" Size="Size.Small"
                        Class="mb-3" />

                    @if (_checkinResp.Sessio.Recursos?.Count > 0)
                    {
                        <MudDivider Class="mb-3" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2 d-block"
                                 Style="text-transform:uppercase;letter-spacing:.05em;font-weight:600;text-align:center">
                            Recursos
                        </MudText>
                        <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:16px;margin-bottom:.75rem">
                            @foreach (var recurs in _checkinResp.Sessio.Recursos.OrderBy(r => r.Ordre))
                            {
                                <MudTooltip Text="@recurs.Etiqueta" Placement="Placement.Top">
                                    <MudIconButton Icon="@IconaMatIcon(recurs.Icona)"
                                                   Color="Color.Primary"
                                                   Variant="Variant.Outlined"
                                                   Size="Size.Large"
                                                   Href="@recurs.Url" Target="_blank" />
                                </MudTooltip>
                            }
                        </div>
                        <MudDivider Class="mb-3" />
                    }

                    <MudStack Row="true" Spacing="4" Class="mb-4" Style="opacity:.6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            IP: @(string.IsNullOrWhiteSpace(CircuitState.ClientIp) ? "—" : CircuitState.ClientIp)
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Sessió #@_checkinResp.Sessio.SessioId
                        </MudText>
                    </MudStack>

                    <MudButton Variant="Variant.Outlined" Color="Color.Error" FullWidth="true"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Logout"
                               OnClick="() => _confirmarSortida = true">
                        @Loc["ExamenPortal_ExitExam"]
                    </MudButton>
                </div>

            </MudPaper>
        </MudContainer>
    </div>
}

<!-- Diàleg de confirmació de sortida voluntària -->
<MudDialog @bind-Visible="_confirmarSortida">
    <TitleContent>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Logout" Color="Color.Error" />
            <MudText Typo="Typo.h6">@Loc["ExamenPortal_ExitTitle"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Warning">
            @Loc["ExamenPortal_ExitConfirm"]
        </MudAlert>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _confirmarSortida = false">
            @Loc["Action_Cancel"]
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error"
                   OnClick="SortirExamen" Disabled="_carregant">
            @Loc["ExamenPortal_ExitConfirmBtn"]
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Diàleg d'expulsió pel professor -->
<MudDialog @bind-Visible="_mostrarExpulsat">
    <TitleContent>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Block" Color="Color.Error" />
            <MudText Typo="Typo.h6">@Loc["ExamenPortal_ExpulsatTitle"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
            @Loc["ExamenPortal_ExpulsatMsg"]
        </MudAlert>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="TancarExpulsat">
            @Loc["Action_Accept"]
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Diàleg obligatori del missatge del professor -->
<MudDialog @bind-Visible="_mostrarMissatge">
    <TitleContent>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Campaign" Color="Color.Warning" />
            <MudText Typo="Typo.h6">@Loc["ExamenPortal_TeacherMsg"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
            @_missatgeProfessor
        </MudAlert>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Warning"
                   OnClick="@(() => _mostrarMissatge = false)">
            @Loc["ExamenPortal_ReadMsg"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private static string IconaMatIcon(string nom)
    {
        var field = typeof(Icons.Material.Filled).GetField(nom,
            System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.Static);
        return field?.GetValue(null) as string ?? Icons.Material.Filled.Link;
    }

    private enum Fase { Email, Connectat }

    private int CheckinInterval => _checkinResp?.Sessio.IntervalSegons ?? 30;

    private Fase    _fase = Fase.Email;
    private string  _email       = "";
    private string? _errorEmail;
    private bool    _carregant;
    private string  _dominiEmail = "sarria.salesians.cat";

    private CheckinResponse? _checkinResp;
    private DateTime _ultimCheckin;
    private int      _segonsRestants;
    private System.Threading.Timer? _timer;

    private bool   _mostrarMissatge;
    private string _missatgeProfessor = "";
    private bool   _confirmarSortida;
    private bool   _mostrarExpulsat;

    private Func<string, object, Task>? _alumneHandler;

    protected override void OnInitialized()
    {
        _dominiEmail = Config["Examen:DominiEmail"] ?? "sarria.salesians.cat";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        // Llegeix la IP injectada pel servidor a App.razor via window.__entornClientIp.
        // Necessari perquè App.razor corre en scope HTTP (DI instance A) i Portal.razor
        // en scope de circuit (DI instance B); la variable JS és l'únic canal entre ambdós.
        var ip = await JS.InvokeAsync<string>("getClientIp");
        if (!string.IsNullOrWhiteSpace(ip))
            CircuitState.ClientIp = ip;
    }

    private async Task OnEmailKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ValidarEmail();
    }

    private async Task ValidarEmail()
    {
        _errorEmail = null;

        var email = _email.Trim().ToLower();
        if (!email.Contains('@'))
            email = $"{email}@{_dominiEmail}";

        _email = email;
        await FerCheckin();
    }

    private async Task FerCheckin()
    {
        _carregant  = true;
        _errorEmail = null;
        StateHasChanged();

        var (resp, error) = await Api.ExamenCheckinAsync(new CheckinRequest(_email.Trim()));

        _carregant = false;

        if (error is not null)
        {
            _errorEmail = error;
            _fase = Fase.Email;
        }
        else if (resp is not null)
        {
            _checkinResp    = resp;
            _ultimCheckin   = DateTime.UtcNow;
            _segonsRestants = resp.Sessio.IntervalSegons;
            _fase           = Fase.Connectat;

            CircuitState.StudentId = resp.Alumne.StudentId;
            CircuitState.Email     = _email.Trim();

            if (!string.IsNullOrWhiteSpace(resp.Sessio.MissatgeActiu))
            {
                _missatgeProfessor = resp.Sessio.MissatgeActiu;
                _mostrarMissatge   = true;
            }

            SubscriuNotificacions(resp.Alumne.StudentId);
            IniciaTimer();
        }

        StateHasChanged();
    }

    private void SubscriuNotificacions(int studentId)
    {
        _alumneHandler = async (eventNom, data) =>
        {
            switch (eventNom)
            {
                case "MissatgeProfessor" when data is ExamenEventMissatge msg:
                    _missatgeProfessor = msg.Text;
                    _mostrarMissatge   = true;
                    await InvokeAsync(StateHasChanged);
                    break;
                case "SessioTancadaGlobal":
                    _checkinResp = null;
                    _fase        = Fase.Email;
                    _errorEmail  = Loc["ExamenPortal_SessionEnded"].Value;
                    _timer?.Dispose();
                    _timer = null;
                    CircuitState.StudentId = null;
                    CircuitState.Email     = null;
                    await InvokeAsync(StateHasChanged);
                    break;
                case "AlumneExpulsat":
                    _mostrarExpulsat = true;
                    await InvokeAsync(StateHasChanged);
                    break;
                case "RecursosActualitzats" when data is List<RecursExamenDto> recursos:
                    if (_checkinResp is not null)
                        _checkinResp = _checkinResp with {
                            Sessio = _checkinResp.Sessio with { Recursos = recursos }
                        };
                    await InvokeAsync(StateHasChanged);
                    break;
            }
        };
        ExamenNotif.SubscriuAlumne(studentId, _alumneHandler);
    }

    private async Task SortirExamen()
    {
        _confirmarSortida = false;
        _carregant = true;
        StateHasChanged();
        await Api.SortirExamenAsync();
        _carregant = false;
        var studentId = _checkinResp?.Alumne.StudentId;
        _checkinResp  = null;
        _fase         = Fase.Email;
        _errorEmail   = null;
        _timer?.Dispose();
        _timer = null;
        CircuitState.StudentId = null;
        CircuitState.Email     = null;
        if (_alumneHandler is not null && studentId.HasValue)
            ExamenNotif.DesubscriuAlumne(studentId.Value, _alumneHandler);
        _alumneHandler = null;
        StateHasChanged();
    }

    private void TancarExpulsat()
    {
        _mostrarExpulsat = false;
        var studentId    = _checkinResp?.Alumne.StudentId;
        _checkinResp     = null;
        _fase            = Fase.Email;
        _errorEmail      = Loc["ExamenPortal_ExpulsatMsg"].Value;
        _timer?.Dispose();
        _timer = null;
        CircuitState.StudentId = null;
        CircuitState.Email     = null;
        if (_alumneHandler is not null && studentId.HasValue)
            ExamenNotif.DesubscriuAlumne(studentId.Value, _alumneHandler);
        _alumneHandler = null;
        StateHasChanged();
    }

    private void IniciaTimer()
    {
        _timer?.Dispose();
        _segonsRestants = CheckinInterval;

        _timer = new System.Threading.Timer(async _ =>
        {
            _segonsRestants--;
            var immediat = CircuitState.PendingImmediateCheckin;
            if (immediat) CircuitState.PendingImmediateCheckin = false;

            if (_segonsRestants <= 0 || immediat)
            {
                _segonsRestants = CheckinInterval;
                // Només fa check-in si el circuit SignalR del navegador és actiu.
                // Quan el navegador perd la WiFi, el circuit cau però el timer
                // segueix corrent al servidor; sense aquesta guarda, el check-in
                // sobreescriuria qualsevol desconnexió detectada per DHCP.
                if (_checkinResp is not null && CircuitState.IsCircuitConnected)
                {
                    var (resp, _) = await Api.ExamenCheckinAsync(new CheckinRequest(_email.Trim()));
                    if (resp is not null) _ultimCheckin = DateTime.UtcNow;
                }
            }
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    public void Dispose()
    {
        _timer?.Dispose();
        CircuitState.StudentId = null;
        CircuitState.Email     = null;
        var studentId = _checkinResp?.Alumne.StudentId;
        if (_alumneHandler is not null && studentId.HasValue)
            ExamenNotif.DesubscriuAlumne(studentId.Value, _alumneHandler);
    }
}
