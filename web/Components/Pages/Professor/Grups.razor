@page "/professor/grups/{ActivityId:int}"
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav
@inject IDialogService Dialog
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResources> Loc

<PageTitle>Grups – Entorn d'Examens</PageTitle>
@if (!UserState.IsProfessor) { Nav.NavigateTo("/"); return; }

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Wrap="Wrap.Wrap">
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Href="/professor/dashboard" Variant="Variant.Text">
        @Loc["Nav_Dashboard"]
    </MudButton>
    <MudText Typo="Typo.h5">@(_activity?.Name ?? "Grups")</MudText>
    @if (_activity is not null)
    {
        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@_activity.ClassName</MudChip>
    }
    <MudSpacer />
    @if (_activity is not null)
    {
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Tune"
                   OnClick="() => _showCriteria = !_showCriteria">
            @Loc["Groups_Criteria"]
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Download"
                   OnClick="ExportGroupsAsync">
            @Loc["Groups_ExportGroups"]
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Upload"
                   OnClick="() => _showImport = !_showImport">
            @Loc["Groups_ImportGroups"]
        </MudButton>
    }
</MudStack>

@if (_showCriteria)
{
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.subtitle1" Class="mb-1"><strong>@Loc["Groups_CriteriaTitle"]</strong></MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
            @Loc["Groups_CriteriaInfo"]
        </MudText>
        @foreach (var (item, idx) in _criteriaItems.Select((x, i) => (x, i)))
        {
            var capturedIdx = idx;
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                <MudTextField Value="item.Label"
                              ValueChanged='(string v) => _criteriaItems[capturedIdx] = new CriterionItem(_criteriaItems[capturedIdx].Key, v)'
                              Label="@Loc["Groups_CriterionN", capturedIdx + 1]"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Style="flex:1" Immediate="true" />
                <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small"
                               Disabled="idx == 0"
                               OnClick="() => MoveCriterion(idx, -1)" />
                <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small"
                               Disabled="idx == _criteriaItems.Count - 1"
                               OnClick="() => MoveCriterion(idx, 1)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                               Color="Color.Error"
                               Disabled="_criteriaItems.Count <= 1"
                               OnClick="() => _criteriaItems.RemoveAt(idx)" />
            </MudStack>
        }
        <MudStack Row="true" Spacing="2" Class="mt-3">
            <MudButton Variant="Variant.Outlined" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick='() => _criteriaItems.Add(new CriterionItem("criteri" + (_criteriaItems.Count+1), "Nou criteri"))'>
                @Loc["Groups_AddCriterion"]
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveCriteriaAsync" Disabled="_savingCriteria">
                @if (_savingCriteria) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                @Loc["Groups_SaveCriteria"]
            </MudButton>
            <MudButton Variant="Variant.Text" Size="Size.Small"
                       OnClick="ResetCriteriaToDefaultAsync">
                @Loc["Groups_ResetGlobals"]
            </MudButton>
        </MudStack>
    </MudPaper>
}

@if (_showImport)
{
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.subtitle1" Class="mb-1"><strong>@Loc["Groups_ImportTitle"]</strong></MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
            @Loc["Groups_ImportInfo"]
        </MudText>
        <MudFileUpload T="IBrowserFile" FilesChanged="OnFileSelected" Accept=".csv,.txt" Class="mb-3">
            <ActivatorContent>
                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.AttachFile">
                    @(_importFileName ?? Loc["Groups_SelectCSV"].Value)
                </MudButton>
            </ActivatorContent>
        </MudFileUpload>
        @if (_importContent is not null)
        {
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Info"
                           OnClick="ImportGroupsAsync" Disabled="_importing">
                    @if (_importing) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Importar
                </MudButton>
                <MudButton OnClick="() => { _importContent = null; _importFileName = null; }">@Loc["Groups_Clear"]</MudButton>
            </MudStack>
        }
    </MudPaper>
}

@if (_loading) { <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" /> }

<!-- Nou grup -->
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="2" Wrap="Wrap.Wrap">
    <MudTextField @bind-Value="_nomGrup" Label="@Loc["Groups_NewGroupLabel"]" Variant="Variant.Outlined"
                  Margin="Margin.Dense" Style="max-width:240px" Immediate="true"
                  OnKeyDown="OnNomGrupKeyDown" />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="CreateGroupAsync" Disabled="_saving || string.IsNullOrWhiteSpace(_nomGrup)">
        @Loc["Groups_CreateGroup"]
    </MudButton>
    <MudText Typo="Typo.caption" Color="Color.Secondary">
        @Loc["Groups_DragInstruction"]
    </MudText>
</MudStack>

<MudGrid Spacing="3" Class="@(_draggingStudentId != null ? "is-dragging" : "")">

    <!-- Columna esquerra: "Sense grup" (fixa) -->
    <MudItem xs="12" md="3">
        <div class="dnd-zone @(_dragOverUnassigned ? "dnd-zone--over" : "") @(_draggingFromGroupId == null && _draggingStudentId != null ? "dnd-zone--source" : "")"
             style="height:100%"
             @ondragenter="() => _dragOverUnassigned = true"
             @ondragleave="OnDragLeaveUnassigned"
             @ondrop:preventDefault
             @ondrop="OnDropToUnassigned">
            <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight:700">
                <MudIcon Icon="@Icons.Material.Filled.PersonOff" Size="Size.Small"
                         Style="vertical-align:middle;margin-right:4px" />
                @Loc["Groups_Unassigned", _unassigned.Count]
            </MudText>

            @if (!_unassigned.Any() && _draggingStudentId == null)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @Loc["Groups_AllAssigned"]
                </MudText>
            }

            <div class="dnd-members" style="max-height:400px;overflow-y:auto">
                @foreach (var s in _unassigned)
                {
                    var sid = s.Id;
                    <div class="dnd-chip dnd-chip--unassigned @(_draggingStudentId == sid ? "dnd-chip--dragging" : "")"
                         draggable="true"
                         @ondragstart="() => OnDragStart(sid, null)"
                         @ondragend="OnDragEnd">
                        <MudIcon Icon="@Icons.Material.Filled.DragIndicator"
                                 Size="Size.Small" Class="dnd-handle" />
                        <span>@s.NumLlista. @s.Cognoms, @s.Nom</span>
                    </div>
                }
            </div>
        </div>
    </MudItem>

    <!-- Columna dreta: grid de grups (3 columnes) -->
    <MudItem xs="12" md="9">
        @if (!_groups.Any())
        {
            <MudAlert Severity="Severity.Info">@Loc["Groups_NoGroups"]</MudAlert>
        }
        <MudGrid Spacing="3">
        @foreach (var g in _groups)
        {
            var gid = g.Id;
            var isOver = _dragOverGroupId == gid;
            var isSameSource = _draggingFromGroupId == gid;

            <MudItem xs="12" sm="6" md="4">
                <div class="dnd-zone @(isOver ? "dnd-zone--over" : "") @(isSameSource ? "dnd-zone--source" : "")"
                     @ondragenter="() => _dragOverGroupId = gid"
                     @ondragleave="() => { if (_dragOverGroupId == gid) _dragOverGroupId = null; }"
                     @ondrop:preventDefault
                     @ondrop="() => OnDropToGroup(gid)">

                    @{ var gidx = _groups.IndexOf(g); }
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                        @if (_editingGroupId == gid)
                        {
                            <MudTextField @bind-Value="_editingGroupName"
                                          Variant="Variant.Outlined" Margin="Margin.Dense"
                                          Style="flex:1;min-width:0" Immediate="true"
                                          @onkeydown="OnRenameKeyDown" />
                            <MudIconButton Icon="@Icons.Material.Filled.Check" Size="Size.Small"
                                           Color="Color.Success" title="@Loc["Groups_RenameConfirm"]"
                                           OnClick="() => RenameGroupAsync(gid)" />
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                           Color="Color.Default" title="@Loc["Action_Cancel"]"
                                           OnClick="CancelRename" />
                        }
                        else
                        {
                            <MudText Typo="Typo.subtitle2" Style="font-weight:700;flex:1">@g.Name</MudText>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                     Style="height:20px;font-size:.7rem">
                                @g.Members.Count
                            </MudChip>
                            <MudIconButton Icon="@Icons.Material.Filled.DriveFileRenameOutline" Size="Size.Small"
                                           title="@Loc["Groups_RenameGroup"]"
                                           OnClick="() => StartRename(gid, g.Name)" />
                            <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small"
                                           Disabled="gidx <= 0" title="Pujar grup"
                                           OnClick="() => MoveGroupAsync(gidx, -1)" />
                            <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small"
                                           Disabled="gidx >= _groups.Count - 1" title="Baixar grup"
                                           OnClick="() => MoveGroupAsync(gidx, 1)" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error" title="Eliminar grup"
                                           OnClick="() => DeleteGroupAsync(g)" />
                        }
                    </MudStack>

                <div class="dnd-members">
                    @foreach (var m in g.Members)
                    {
                        var mid = m.Id;
                        <div class="dnd-chip @(_draggingStudentId == mid ? "dnd-chip--dragging" : "")"
                             draggable="true"
                             @ondragstart="() => OnDragStart(mid, gid)"
                             @ondragend="OnDragEnd">
                            <MudIcon Icon="@Icons.Material.Filled.DragIndicator"
                                     Size="Size.Small" Class="dnd-handle" />
                            <span style="flex:1">@m.NumLlista. @m.Cognoms, @m.Nom</span>
                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                           Size="Size.Small" Color="Color.Warning"
                                           title="@Loc["Groups_RemoveMember"]"
                                           OnClick="() => RemoveMemberAsync(gid, mid)"
                                           Style="margin:-4px -4px -4px 0;width:24px;height:24px" />
                        </div>
                    }

                    @if (!g.Members.Any())
                    {
                        <div class="dnd-empty-hint">
                            @Loc["Groups_DragHere"]
                        </div>
                    }
                </div>
            </div>
        </MudItem>
        }
        </MudGrid>
    </MudItem>

</MudGrid>

@code {
    [Parameter] public int ActivityId { get; set; }

    private ActivityDto?      _activity   = null;
    private List<GroupDto>    _groups     = [];
    private List<StudentDto>  _unassigned = [];
    private bool _loading  = true;
    private bool _saving   = false;
    private string _nomGrup = "";
    private bool _showImport    = false;
    private bool _importing     = false;
    private string? _importContent  = null;
    private string? _importFileName = null;

    // ── Criteris inline ──────────────────────────────────────────────────────
    private bool _showCriteria  = false;
    private bool _savingCriteria = false;
    private List<CriterionItem> _criteriaItems = [];

    // ── Renomenar grup inline ────────────────────────────────────────────────
    private int?   _editingGroupId   = null;
    private string _editingGroupName = "";

    // ── Reordenació de grups ─────────────────────────────────────────────────

    // ── Estat drag & drop ────────────────────────────────────────────────────
    private int?  _draggingStudentId  = null;
    private int?  _draggingFromGroupId = null;  // null = ve de "sense grup"
    private int?  _dragOverGroupId    = null;
    private bool  _dragOverUnassigned = false;
    private bool  _dragBusy           = false;

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsProfessor) return;
        await LoadAsync();
        _loading = false;
    }

    private async Task LoadAsync()
    {
        Api.SetToken(UserState.Token!);
        _activity = await Api.GetActivityAsync(ActivityId);
        if (_activity is null) return;

        _groups = await Api.GetGroupsAsync(ActivityId) ?? [];
        var allStudents = await Api.GetStudentsAsync(_activity.ClassId) ?? [];

        var exclusions  = await Api.GetExclusionsAsync(_activity.ModuleId) ?? [];
        var excludedIds = exclusions.Select(e => e.StudentId).ToHashSet();
        var assignedIds = _groups.SelectMany(g => g.Members).Select(m => m.Id).ToHashSet();

        _unassigned = allStudents
            .Where(s => !assignedIds.Contains(s.Id) && !excludedIds.Contains(s.Id))
            .OrderBy(s => s.NumLlista)
            .ToList();

        await LoadCriteriaAsync();
    }

    private async Task LoadCriteriaAsync()
    {
        Api.SetToken(UserState.Token!);
        var criteria = await Api.GetActivityCriteriaAsync(ActivityId) ?? [];
        _criteriaItems = criteria.Select(c => new CriterionItem(c.Key, c.Label)).ToList();
        if (!_criteriaItems.Any())
            _criteriaItems = (await Api.GetCriteriaAsync() ?? [])
                .Select(c => new CriterionItem(c.Key, c.Label)).ToList();
    }

    private void MoveCriterion(int idx, int delta)
    {
        var newIdx = idx + delta;
        if (newIdx < 0 || newIdx >= _criteriaItems.Count) return;
        (_criteriaItems[idx], _criteriaItems[newIdx]) = (_criteriaItems[newIdx], _criteriaItems[idx]);
    }

    private async Task SaveCriteriaAsync()
    {
        var valid = _criteriaItems.Where(c => !string.IsNullOrWhiteSpace(c.Label)).ToList();
        if (!valid.Any()) { Snackbar.Add(Loc["Groups_MinOneCriterion"], Severity.Warning); return; }

        _savingCriteria = true;
        Api.SetToken(UserState.Token!);
        // Genera claus úniques a partir del label
        var items = valid.Select((c, i) =>
        {
            var key = string.IsNullOrWhiteSpace(c.Key) || c.Key.StartsWith("criteri")
                ? "c" + (i + 1)
                : c.Key;
            return new CriterionItem(key, c.Label.Trim());
        }).ToList();
        var saved = await Api.SaveActivityCriteriaAsync(ActivityId, new SaveCriteriaRequest(items));
        _savingCriteria = false;
        if (saved is not null)
        {
            _criteriaItems = saved.Select(c => new CriterionItem(c.Key, c.Label)).ToList();
            Snackbar.Add(Loc["Groups_CriteriaSaved"], Severity.Success);
        }
        else Snackbar.Add(Loc["Groups_CriteriaSaveErr"], Severity.Error);
    }

    private async Task ResetCriteriaToDefaultAsync()
    {
        // Esborra criteris personalitzats → s'usaran els globals
        Api.SetToken(UserState.Token!);
        // Enviar llista buida no és vàlid (mínim 1), usem els globals com a llista
        var globals = await Api.GetCriteriaAsync() ?? [];
        var items   = globals.Select(c => new CriterionItem(c.Key, c.Label)).ToList();
        var saved   = await Api.SaveActivityCriteriaAsync(ActivityId, new SaveCriteriaRequest(items));
        if (saved is not null)
        {
            _criteriaItems = saved.Select(c => new CriterionItem(c.Key, c.Label)).ToList();
            Snackbar.Add(Loc["Groups_GlobalsReset"], Severity.Success);
        }
    }

    private async Task MoveGroupAsync(int idx, int delta)
    {
        var newIdx = idx + delta;
        if (newIdx < 0 || newIdx >= _groups.Count) return;
        (_groups[idx], _groups[newIdx]) = (_groups[newIdx], _groups[idx]);
        Api.SetToken(UserState.Token!);
        await Api.ReorderGroupsAsync(ActivityId, _groups.Select(g => g.Id).ToList());
    }

    // ── Renomenar grups ──────────────────────────────────────────────────────

    private void StartRename(int groupId, string currentName)
    {
        _editingGroupId   = groupId;
        _editingGroupName = currentName;
    }

    private void CancelRename()
    {
        _editingGroupId   = null;
        _editingGroupName = "";
    }

    private async Task OnRenameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && _editingGroupId.HasValue)
            await RenameGroupAsync(_editingGroupId.Value);
        else if (e.Key == "Escape")
            CancelRename();
    }

    private async Task RenameGroupAsync(int groupId)
    {
        if (string.IsNullOrWhiteSpace(_editingGroupName)) { CancelRename(); return; }
        Api.SetToken(UserState.Token!);
        var ok = await Api.RenameGroupAsync(ActivityId, groupId, _editingGroupName.Trim());
        CancelRename();
        if (ok)
        {
            await LoadAsync();
            Snackbar.Add(Loc["Groups_GroupRenamed"], Severity.Success);
        }
        else
            Snackbar.Add(Loc["Groups_GroupRenameErr"], Severity.Error);
    }

    // ── Crear / esborrar grups ───────────────────────────────────────────────

    private async Task CreateGroupAsync()
    {
        if (string.IsNullOrWhiteSpace(_nomGrup)) return;
        _saving = true;
        Api.SetToken(UserState.Token!);
        await Api.CreateGroupAsync(ActivityId, _nomGrup.Trim());
        _nomGrup = "";
        await LoadAsync();
        _saving = false;
        Snackbar.Add(Loc["Groups_GroupCreated"], Severity.Success);
    }

    private async Task OnNomGrupKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await CreateGroupAsync();
    }

    private async Task DeleteGroupAsync(GroupDto g)
    {
        var membresText = g.Members.Count > 0
            ? $" Els {g.Members.Count} membres quedaran sense grup assignat."
            : "";
        var confirm = await Dialog.ShowMessageBox(Loc["Groups_DeleteGroupTitle"],
            Loc["Groups_DeleteGroupMsg", g.Name, membresText].Value,
            yesText: Loc["Action_Delete"], cancelText: Loc["Action_Cancel"]);
        if (confirm != true) return;
        Api.SetToken(UserState.Token!);
        await Api.DeleteGroupAsync(ActivityId, g.Id);
        await LoadAsync();
        Snackbar.Add(Loc["Groups_GroupDeleted"], Severity.Info);
    }

    // ── Drag & Drop ──────────────────────────────────────────────────────────

    private void OnDragStart(int studentId, int? fromGroupId)
    {
        _draggingStudentId   = studentId;
        _draggingFromGroupId = fromGroupId;
    }

    private void OnDragEnd()
    {
        _draggingStudentId   = null;
        _draggingFromGroupId = null;
        _dragOverGroupId     = null;
        _dragOverUnassigned  = false;
    }

    private void OnDragLeaveUnassigned()
    {
        _dragOverUnassigned = false;
    }

    private async Task OnDropToGroup(int groupId)
    {
        if (_draggingStudentId is null || _dragBusy) return;

        // Capturar valors ara, abans de qualsevol await:
        // events posteriors (ondragend) poden nullificar els camps
        var studentId   = _draggingStudentId.Value;
        var fromGroupId = _draggingFromGroupId;

        if (fromGroupId == groupId) { OnDragEnd(); return; }

        _dragBusy = true;
        OnDragEnd();
        Api.SetToken(UserState.Token!);

        if (fromGroupId.HasValue)
            await Api.RemoveMemberAsync(ActivityId, fromGroupId.Value, studentId);

        await Api.AddMemberAsync(ActivityId, groupId, studentId);

        _dragBusy = false;
        await LoadAsync();
    }

    private async Task OnDropToUnassigned()
    {
        if (_draggingStudentId is null || _draggingFromGroupId is null || _dragBusy) return;

        var studentId   = _draggingStudentId.Value;
        var fromGroupId = _draggingFromGroupId.Value;

        _dragBusy = true;
        OnDragEnd();
        Api.SetToken(UserState.Token!);
        await Api.RemoveMemberAsync(ActivityId, fromGroupId, studentId);

        _dragBusy = false;
        await LoadAsync();
    }

    // ── Treure membre (botó X) ───────────────────────────────────────────────

    private async Task RemoveMemberAsync(int groupId, int studentId)
    {
        var confirm = await Dialog.ShowMessageBox(
            Loc["Groups_RemoveMemberTitle"], Loc["Groups_RemoveMemberMsg"].Value,
            yesText: Loc["Groups_RemoveMemberYes"], cancelText: Loc["Action_Cancel"]);
        if (confirm != true) return;
        Api.SetToken(UserState.Token!);
        await Api.RemoveMemberAsync(ActivityId, groupId, studentId);
        await LoadAsync();
    }

    // ── Export / Import ──────────────────────────────────────────────────────

    private async Task ExportGroupsAsync()
    {
        Api.SetToken(UserState.Token!);
        var result = await Api.ExportGroupsAsync(ActivityId);
        if (result is null) { Snackbar.Add(Loc["Groups_ExportError"], Severity.Error); return; }
        var (bytes, fileName) = result.Value;
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadBase64File", base64, fileName, "text/csv");
    }

    private async Task OnFileSelected(IBrowserFile file)
    {
        _importFileName = file.Name;
        using var reader = new System.IO.StreamReader(file.OpenReadStream(maxAllowedSize: 1_048_576));
        _importContent  = await reader.ReadToEndAsync();
    }

    private async Task ImportGroupsAsync()
    {
        if (_importContent is null) return;
        _importing = true;
        Api.SetToken(UserState.Token!);
        var result = await Api.ImportGroupsAsync(ActivityId, _importContent);
        _importing = false;

        if (result is null) { Snackbar.Add(Loc["Groups_ImportError"], Severity.Error); return; }

        Snackbar.Add(Loc["Groups_ImportSuccess", result.Assigned, result.Skipped],
            result.Skipped > 0 ? Severity.Warning : Severity.Success);

        if (result.Errors.Any())
            foreach (var e in result.Errors.Take(5))
                Snackbar.Add(e, Severity.Warning);

        _importContent  = null;
        _importFileName = null;
        _showImport     = false;
        await LoadAsync();
    }
}
