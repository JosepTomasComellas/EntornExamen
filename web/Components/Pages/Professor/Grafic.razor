@page "/professor/grafic/{ActivityId:int}"
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResources> Loc
@implements IAsyncDisposable

<PageTitle>Gràfic – Entorn d'Examens</PageTitle>
@if (!UserState.IsProfessor) { Nav.NavigateTo("/"); return; }

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Wrap="Wrap.Wrap">
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text"
               Href="@($"/professor/resultats/{ActivityId}")">
        @Loc["Nav_Results"]
    </MudButton>
    @if (_data is not null)
    {
        <MudText Typo="Typo.h5">@_data.ActivityName</MudText>
        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@_data.ClassName</MudChip>
    }
    <MudSpacer />
    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Primary" OnClick="LoadAsync" />
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_data is null)
{
    <MudAlert Severity="Severity.Error">@Loc["Chart_NoData"]</MudAlert>
}
else if (!_data.Groups.Any())
{
    <MudAlert Severity="Severity.Info">@Loc["Chart_NoEvals"]</MudAlert>
}
else
{
    <MudGrid Spacing="3">
        <!-- Gràfic principal: Auto vs Co per grup -->
        <MudItem xs="12" md="7">
            <MudPaper Elevation="2" Class="pa-4">
                <MudText Typo="Typo.subtitle1" Style="font-weight:700;margin-bottom:1rem">
                    @Loc["Chart_AutoVsCo"]
                </MudText>
                <canvas id="chart-groups" style="max-height:320px"></canvas>
            </MudPaper>
        </MudItem>

        <!-- Estadístiques de participació -->
        <MudItem xs="12" md="5">
            <MudPaper Elevation="2" Class="pa-4">
                <MudText Typo="Typo.subtitle1" Style="font-weight:700;margin-bottom:1rem">
                    @Loc["Chart_Participation"]
                </MudText>
                <MudSimpleTable Dense="true" Hover="true">
                    <thead>
                        <tr>
                            <th>@Loc["Chart_ColGroup"]</th>
                            <th style="text-align:right">@Loc["Chart_ColTotal"]</th>
                            <th style="text-align:right">@Loc["Chart_ColAuto"]</th>
                            <th style="text-align:right">@Loc["Chart_ColCo"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var g in _data.Groups)
                        {
                            <tr>
                                <td>@g.GroupName</td>
                                <td style="text-align:right">@g.NumStudentsTotal</td>
                                <td style="text-align:right">
                                    <span class="@(g.NumStudentsWithAuto == g.NumStudentsTotal ? "grade-high" : "grade-mid")">
                                        @g.NumStudentsWithAuto
                                    </span>
                                </td>
                                <td style="text-align:right">
                                    <span class="@(g.NumStudentsWithCo == g.NumStudentsTotal ? "grade-high" : "grade-mid")">
                                        @g.NumStudentsWithCo
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>

                <!-- Notes globals -->
                <MudDivider Class="my-3" />
                @foreach (var g in _data.Groups)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
                        <MudText Typo="Typo.body2" Style="min-width:80px;font-weight:600">@g.GroupName</MudText>
                        @if (g.AvgAutoEval.HasValue)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                                @($"{Loc["Chart_ColAuto"].Value}: {g.AvgAutoEval.Value:F1}")
                            </MudChip>
                        }
                        @if (g.AvgCoEval.HasValue)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">
                                @($"{Loc["Chart_ColCo"].Value}: {g.AvgCoEval.Value:F1}")
                            </MudChip>
                        }
                    </MudStack>
                }
            </MudPaper>
        </MudItem>

        <!-- Gràfic per criteri -->
        @if (_data.CriteriaDetail.Any())
        {
            <MudItem xs="12">
                <MudPaper Elevation="2" Class="pa-4">
                    <MudText Typo="Typo.subtitle1" Style="font-weight:700;margin-bottom:1rem">
                        @Loc["Chart_CriteriaDetail"]
                    </MudText>
                    <canvas id="chart-criteria" style="max-height:360px"></canvas>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}

@code {
    [Parameter] public int ActivityId { get; set; }

    private ActivityChartDto? _data    = null;
    private bool              _loading = true;
    private bool              _chartsDrawn = false;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading     = true;
        _chartsDrawn = false;
        Api.SetToken(UserState.Token!);
        _data    = await Api.GetChartAsync(ActivityId);
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_data is null || _chartsDrawn) return;

        try
        {
            // Gràfic Auto vs Co per grup
            var groupLabels  = _data.Groups.Select(g => g.GroupName).ToArray();
            var autoData     = _data.Groups.Select(g => g.AvgAutoEval).ToArray();
            var coData       = _data.Groups.Select(g => g.AvgCoEval).ToArray();

            await JS.InvokeVoidAsync("autocoCharts.renderBar", "chart-groups",
                groupLabels,
                new[] {
                    new { label = Loc["Chart_AutoEvalLabel"].Value, data = autoData, color = "#CC0000" },
                    new { label = Loc["Chart_CoEvalLabel"].Value,   data = coData,   color = "#1e293b" }
                });

            // Gràfic per criteri
            if (_data.CriteriaDetail.Any())
            {
                var criteriaLabels = _data.CriteriaDetail.Select(c => c.CriteriaLabel).ToArray();
                var groups         = _data.Groups.Select(g => g.GroupName).ToArray();

                var autoSeries = groups.Select((g, gi) => new
                {
                    label = $"{g} ({Loc["Chart_ColAuto"].Value})",
                    data  = _data.CriteriaDetail.Select(c =>
                        c.Groups.FirstOrDefault(cg => cg.GroupName == g)?.AvgAuto).ToArray(),
                    color = $"hsl({gi * 60}, 65%, 45%)"
                }).ToArray();

                var coSeries = groups.Select((g, gi) => new
                {
                    label = $"{g} ({Loc["Chart_ColCo"].Value})",
                    data  = _data.CriteriaDetail.Select(c =>
                        c.Groups.FirstOrDefault(cg => cg.GroupName == g)?.AvgCo).ToArray(),
                    color = $"hsl({gi * 60}, 40%, 68%)"
                }).ToArray();

                await JS.InvokeVoidAsync("autocoCharts.renderBar", "chart-criteria",
                    criteriaLabels,
                    autoSeries.Concat(coSeries).ToArray());
            }

            _chartsDrawn = true;
        }
        catch { /* Chart.js potser no ha carregat encara */ }
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("autocoCharts.destroy", "chart-groups"); } catch { }
        try { await JS.InvokeVoidAsync("autocoCharts.destroy", "chart-criteria"); } catch { }
    }
}
