@page "/professor/moduls/{ClassId:int}"
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav
@inject IDialogService Dialog
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResources> Loc

<PageTitle>Mòduls – Entorn d'Examens</PageTitle>
@if (!UserState.IsProfessor) { Nav.NavigateTo("/"); return; }

@if (_classe is null && !_loading)
{
    <MudAlert Severity="Severity.Error">@Loc["Moduls_ClassNotFound"]</MudAlert>
    <MudButton Href="/professor/classes" Class="mt-2">@Loc["Action_Back"]</MudButton>
    return;
}

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6" Wrap="Wrap.Wrap">
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Href="/professor/classes"
               Variant="Variant.Text" Color="Color.Default">@Loc["Classes_Title"]</MudButton>
    <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
    <MudIcon Icon="@Icons.Material.Filled.MenuBook" Color="Color.Primary" Class="mr-1" />
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Style="font-weight:700">@Loc["Moduls_TitlePage", _classe?.Name ?? ""]</MudText>
        @if (_classe?.AcademicYear is not null)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">@_classe.AcademicYear</MudText>
        }
    </MudStack>
</MudStack>

@if (_loading) { <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" /> }

<MudGrid>
    <MudItem xs="12" md="4">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.subtitle1" Style="font-weight:600">
                        @(_editId == 0 ? Loc["Moduls_NewModule"].Value : Loc["Moduls_EditModule"].Value)
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudTextField @bind-Value="_code" Label="@Loc["Moduls_CodeLabel"]" Variant="Variant.Outlined"
                              Class="mb-3" MaxLength="4" Immediate="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Tag" />
                <MudTextField @bind-Value="_name" Label="@Loc["Moduls_NameLabel"]" Variant="Variant.Outlined"
                              Immediate="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.MenuBook" />
            </MudCardContent>
            <MudCardActions Class="px-4 pb-4 gap-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           OnClick="SaveAsync" Disabled="_saving"
                           StartIcon="@Icons.Material.Filled.Save">
                    @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    @(_editId == 0 ? Loc["Moduls_AddBtn"].Value : Loc["Moduls_SaveBtn"].Value)
                </MudButton>
                @if (_editId != 0)
                {
                    <MudButton Variant="Variant.Text" OnClick="CancelEdit">@Loc["Action_Cancel"]</MudButton>
                }
            </MudCardActions>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="8">
        @if (!_loading && _moduls.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                @Loc["Moduls_NoModules"]
            </MudAlert>
        }
        <MudStack Spacing="2">
            @foreach (var m in _moduls)
            {
                <MudPaper Elevation="2" Class="pa-3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                        <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled"
                                 Size="Size.Small" Style="font-weight:700;font-family:monospace">
                            @m.Code
                        </MudChip>
                        <MudStack Spacing="0" Style="flex:1;min-width:0">
                            <MudText Typo="Typo.subtitle1" Style="font-weight:600">@m.Name</MudText>
                            <MudStack Row="true" Spacing="1">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @m.ActivityCount activitat@(m.ActivityCount != 1 ? "s" : "")
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">·</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@m.ProfessorName</MudText>
                            </MudStack>
                        </MudStack>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Href="@($"/professor/nova-activitat?moduleId={m.Id}")">
                            @Loc["Moduls_NewActivity"]
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.PersonOff"
                                   OnClick="() => ToggleExclusionPanel(m.Id, m.ClassId)">
                            @Loc["Moduls_Exclusions"]
                        </MudButton>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       Color="Color.Default" title="@Loc["Action_Edit"]"
                                       OnClick="() => StartEdit(m)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                       Color="Color.Error" title="@Loc["Action_Delete"]"
                                       OnClick="() => DeleteAsync(m)" />
                    </MudStack>
                    @if (_showExclusions.Contains(m.Id))
                    {
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.subtitle2" Class="mb-2">@Loc["Moduls_ExcludedStudents"]</MudText>
                        @if (!_classeStudents.ContainsKey(m.ClassId))
                        {
                            <MudProgressLinear Indeterminate="true" Color="Color.Warning" />
                        }
                        else
                        {
                            var students = _classeStudents[m.ClassId];
                            var excluded = _exclusions.GetValueOrDefault(m.Id) ?? [];
                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                @foreach (var s in students)
                                {
                                    var isExcluded = excluded.Contains(s.Id);
                                    <MudChip T="string"
                                             Color="@(isExcluded ? Color.Error : Color.Default)"
                                             Variant="@(isExcluded ? Variant.Filled : Variant.Outlined)"
                                             OnClick="() => ToggleExclusionAsync(m.Id, m.ClassId, s)"
                                             Style="cursor:pointer">
                                        @s.NomComplet
                                    </MudChip>
                                }
                            </MudStack>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                @Loc["Moduls_ClickToExclude"]
                            </MudText>
                        }
                    }
                </MudPaper>
            }
        </MudStack>
    </MudItem>
</MudGrid>

@code {
    [Parameter] public int ClassId { get; set; }

    private ClassDto?        _classe  = null;
    private List<ModuleDto>  _moduls  = [];
    private bool _loading = true;
    private bool _saving  = false;

    private string _code   = "";
    private string _name   = "";
    private int    _editId = 0;

    private HashSet<int>                          _showExclusions = [];
    private Dictionary<int, List<StudentDto>>     _classeStudents = new();
    private Dictionary<int, HashSet<int>>         _exclusions     = new();

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsProfessor) return;
        Api.SetToken(UserState.Token!);
        _classe = await Api.GetClassAsync(ClassId);
        _moduls = await Api.GetModulesAsync(ClassId) ?? [];
        _loading = false;
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_code) || _code.Trim().Length > 4 ||
            string.IsNullOrWhiteSpace(_name))
        {
            Snackbar.Add("El codi (màx. 4 car.) i el nom són obligatoris.", Severity.Warning);
            return;
        }
        _saving = true;
        Api.SetToken(UserState.Token!);
        if (_editId == 0)
        {
            var m = await Api.CreateModuleAsync(ClassId, new CreateModuleRequest(_code.Trim(), _name.Trim()));
            if (m is not null) { _moduls.Add(m); _moduls = [.. _moduls.OrderBy(x => x.Code)]; _code = ""; _name = ""; Snackbar.Add($"Mòdul «{m.Code} – {m.Name}» creat.", Severity.Success); }
            else Snackbar.Add("Error en crear el mòdul.", Severity.Error);
        }
        else
        {
            var m = await Api.UpdateModuleAsync(ClassId, _editId, new UpdateModuleRequest(_code.Trim(), _name.Trim()));
            if (m is not null)
            {
                var idx = _moduls.FindIndex(x => x.Id == _editId);
                if (idx >= 0) _moduls[idx] = m;
                _moduls = [.. _moduls.OrderBy(x => x.Code)];
                CancelEdit();
                Snackbar.Add("Mòdul actualitzat.", Severity.Success);
            }
            else Snackbar.Add("Error en actualitzar el mòdul.", Severity.Error);
        }
        _saving = false;
    }

    private void StartEdit(ModuleDto m) { _editId = m.Id; _code = m.Code; _name = m.Name; }
    private void CancelEdit() { _editId = 0; _code = ""; _name = ""; }

    private async Task DeleteAsync(ModuleDto m)
    {
        var confirm = await Dialog.ShowMessageBox("Confirmar eliminació",
            $"Eliminar el mòdul «{m.Code} – {m.Name}»?\n\nS'eliminaran totes les activitats associades i totes les avaluacions que hi hagi guardades. Aquesta acció no es pot desfer.",
            yesText: "Eliminar", cancelText: "Cancel·lar");
        if (confirm != true) return;
        Api.SetToken(UserState.Token!);
        var ok = await Api.DeleteModuleAsync(ClassId, m.Id);
        if (ok) { _moduls.RemoveAll(x => x.Id == m.Id); Snackbar.Add("Mòdul eliminat.", Severity.Info); }
        else Snackbar.Add("Error en eliminar el mòdul.", Severity.Error);
    }

    private async Task ToggleExclusionPanel(int moduleId, int classId)
    {
        if (_showExclusions.Contains(moduleId))
        {
            _showExclusions.Remove(moduleId);
            return;
        }
        _showExclusions.Add(moduleId);
        await LoadModuleDataAsync(moduleId, classId);
    }

    private async Task LoadModuleDataAsync(int moduleId, int classId)
    {
        Api.SetToken(UserState.Token!);
        if (!_classeStudents.ContainsKey(classId))
            _classeStudents[classId] = await Api.GetStudentsAsync(classId) ?? [];

        var excl = await Api.GetExclusionsAsync(moduleId) ?? [];
        _exclusions[moduleId] = excl.Select(e => e.StudentId).ToHashSet();
    }

    private async Task ToggleExclusionAsync(int moduleId, int classId, StudentDto student)
    {
        Api.SetToken(UserState.Token!);
        if (_exclusions.TryGetValue(moduleId, out var set) && set.Contains(student.Id))
        {
            await Api.RemoveExclusionAsync(moduleId, student.Id);
            set.Remove(student.Id);
            Snackbar.Add($"{student.NomComplet} inclòs al mòdul.", Severity.Success);
        }
        else
        {
            await Api.AddExclusionAsync(moduleId, student.Id);
            if (!_exclusions.TryGetValue(moduleId, out set))
            {
                set = [];
                _exclusions[moduleId] = set;
            }
            set.Add(student.Id);
            Snackbar.Add($"{student.NomComplet} exclòs del mòdul.", Severity.Info);
        }
    }
}
