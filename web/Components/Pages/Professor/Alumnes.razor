@page "/professor/alumnes/{ClassId:int}"
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav
@inject IDialogService Dialog
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResources> Loc

<PageTitle>Alumnes – Entorn d'Examens</PageTitle>
@if (!UserState.IsProfessor) { Nav.NavigateTo("/"); return; }

@if (_classe is null && !_loading)
{
    <MudAlert Severity="Severity.Error">@Loc["ClassStudents_ClassNotFound"]</MudAlert>
    <MudButton Href="/professor/classes" Class="mt-2">@Loc["ClassStudents_Back"]</MudButton>
    return;
}

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6" Wrap="Wrap.Wrap">
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Href="/professor/classes"
               Variant="Variant.Text" Color="Color.Default">@Loc["Classes_Title"]</MudButton>
    <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
    <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary" Class="mr-1" />
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Style="font-weight:700">@_classe?.Name</MudText>
        @if (_classe?.AcademicYear is not null)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">@_classe.AcademicYear</MudText>
        }
    </MudStack>
    <MudSpacer />
    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Download"
               OnClick="ExportCsvAsync">
        @Loc["ClassStudents_ExportList"]
    </MudButton>
</MudStack>

@if (_loading) { <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" /> }

<MudGrid>
    @if (UserState.IsAdmin)
    {
        <MudItem xs="12" md="4">
            <MudCard Elevation="2" Class="mb-4">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudAvatar Color="@(_editStudentId == 0 ? Color.Primary : Color.Warning)"
                                   Variant="Variant.Filled" Size="Size.Small">
                            <MudIcon Icon="@(_editStudentId == 0 ? Icons.Material.Filled.PersonAdd : Icons.Material.Filled.Edit)" />
                        </MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@(_editStudentId == 0 ? Loc["ClassStudents_NewStudent"].Value : Loc["ClassStudents_EditStudent"].Value)</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="2">
                        <MudItem xs="6">
                            <MudTextField @bind-Value="_nom" Label="@Loc["Label_Name"]" Variant="Variant.Outlined" Immediate="true" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudTextField @bind-Value="_cognoms" Label="@Loc["Label_Surname"]" Variant="Variant.Outlined" Immediate="true" />
                        </MudItem>
                    </MudGrid>
                    <MudNumericField T="int" @bind-Value="_numLlista" Label="@Loc["ClassStudents_NumLlista"]"
                                     Variant="Variant.Outlined" Min="1" Max="99" Class="mt-3" />
                    <MudTextField @bind-Value="_correu" Label="@Loc["Label_Email"]"
                                  Variant="Variant.Outlined" InputType="InputType.Email"
                                  Class="mt-3" Immediate="true" />
                </MudCardContent>
                <MudCardActions Class="px-4 pb-4 gap-2">
                    @if (_editStudentId == 0)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                   OnClick="AddAsync" Disabled="_saving"
                                   StartIcon="@Icons.Material.Filled.PersonAdd">
                            @Loc["ClassStudents_AddBtn"]
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true"
                                   OnClick="SaveEditAsync" Disabled="_saving"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @Loc["ClassStudents_SaveBtn"]
                        </MudButton>
                        <MudButton Variant="Variant.Text" OnClick="CancelEdit">@Loc["Action_Cancel"]</MudButton>
                    }
                </MudCardActions>
            </MudCard>

            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent><MudText Typo="Typo.h6">@Loc["ClassStudents_ImportTitle"]</MudText></CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                        <strong>CSV:</strong> <code>NumLlista;Nom;Cognoms;Correu</code>
                    </MudText>
                    <MudFileUpload T="IBrowserFile" Accept=".csv,.txt" FilesChanged="OnImportFileSelected">
                        <ActivatorContent>
                            <MudButton Variant="Variant.Outlined" FullWidth="true"
                                       StartIcon="@Icons.Material.Filled.AttachFile">
                                @(_importFile is null ? Loc["ClassStudents_SelectFile"].Value : _importFile.Name)
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>
                </MudCardContent>
                <MudCardActions Class="px-4 pb-4 gap-2">
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                               OnClick="ImportAsync" Disabled="_importFile is null || _saving"
                               StartIcon="@Icons.Material.Filled.Upload">
                        @Loc["ClassStudents_ImportBtn"]
                    </MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                               Href="/templates/alumnes-plantilla.csv" download="alumnes-plantilla.csv"
                               StartIcon="@Icons.Material.Filled.Download">
                        @Loc["ClassStudents_CsvTemplate"]
                    </MudButton>
                </MudCardActions>
            </MudCard>

            @if (_importSummary is not null || _importErrors.Any())
            {
                <MudPaper Elevation="0" Class="pa-3" Style="border:1px solid var(--mud-palette-divider);border-radius:8px">
                    @if (_importSummary is not null)
                    {
                        <MudText Typo="Typo.body2" Class="mb-1" Style="font-weight:600">@_importSummary</MudText>
                    }
                    @if (_importErrors.Any())
                    {
                        <MudText Typo="Typo.caption" Color="Color.Error" Style="font-weight:600">
                            @_importErrors.Count error@(_importErrors.Count == 1 ? "" : "s"):
                        </MudText>
                        <MudList T="string" Dense="true" Class="mt-1 pa-0">
                            @foreach (var err in _importErrors)
                            {
                                <MudListItem T="string" Dense="true" Class="pa-0">
                                    <MudText Typo="Typo.caption" Color="Color.Error">• @err</MudText>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudPaper>
            }

            <!-- ── Importació EPSS ─────────────────────────────────────────── -->
            <MudCard Elevation="2" Class="mt-4">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudAvatar Color="Color.Tertiary" Variant="Variant.Filled" Size="Size.Small">
                            <MudIcon Icon="@Icons.Material.Filled.School" />
                        </MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Loc["Epss_Title"]</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pb-0">

                    <!-- XLS alumnes -->
                    <MudText Typo="Typo.subtitle2" Style="font-weight:600">@Loc["Epss_SubtitleAlumnes"]</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">@Loc["Epss_AlumnesDesc"]</MudText>
                    <MudFileUpload T="IBrowserFile" Accept=".xls,.xlsx" FilesChanged="OnXlsSeleccionat">
                        <ActivatorContent>
                            <MudButton Variant="Variant.Outlined" Color="Color.Tertiary" FullWidth="true" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.AttachFile">
                                @(_xlsFitxer is null ? Loc["Epss_SeleccionaFitxer"].Value : _xlsFitxer.Name)
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>
                    @if (_resultXls is not null)
                    {
                        <MudAlert Severity="Severity.Success" Dense="true" Class="mt-2">
                            @Loc["Epss_ResultatAlumnes", _resultXls.Importats, _resultXls.Actualitzats, _resultXls.Saltats]
                        </MudAlert>
                        @if (_resultXls.Errors.Count > 0)
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-1">
                                <ul style="margin:0 0 0 16px;padding:0">
                                    @foreach (var e in _resultXls.Errors)
                                    { <li><MudText Typo="Typo.caption">@e</MudText></li> }
                                </ul>
                            </MudAlert>
                        }
                    }
                    @if (_errorXls is not null)
                    {
                        <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@_errorXls</MudAlert>
                    }

                    <MudDivider Class="my-3" />

                    <!-- ZIP fotos -->
                    <MudText Typo="Typo.subtitle2" Style="font-weight:600">@Loc["Epss_SubtitleFotos"]</MudText>
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                        <strong>@Loc["Epss_ComObtenir"]</strong>
                        <ol style="margin:4px 0 0 16px;padding:0">
                            <li><MudText Typo="Typo.caption">@Loc["Epss_Pas1"]</MudText></li>
                            <li><MudText Typo="Typo.caption">@Loc["Epss_Pas2"]</MudText></li>
                            <li><MudText Typo="Typo.caption">@Loc["Epss_Pas3"]</MudText></li>
                        </ol>
                    </MudAlert>
                    <MudFileUpload T="IBrowserFile" Accept=".zip" FilesChanged="OnZipSeleccionat">
                        <ActivatorContent>
                            <MudButton Variant="Variant.Outlined" Color="Color.Tertiary" FullWidth="true" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.FolderZip">
                                @(_zipFitxer is null ? Loc["Epss_SeleccionaZip"].Value : _zipFitxer.Name)
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>
                    @if (_resultZip is not null)
                    {
                        <MudAlert Severity="Severity.Success" Dense="true" Class="mt-2">
                            @Loc["Epss_ResultatFotos", _resultZip.Importades]
                        </MudAlert>
                        @if (_resultZip.NoTrobades.Count > 0)
                        {
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-1">
                                <strong>@Loc["Epss_NoTrobades"]</strong>
                                <MudText Typo="Typo.caption">@string.Join(", ", _resultZip.NoTrobades)</MudText>
                            </MudAlert>
                        }
                    }
                    @if (_errorZip is not null)
                    {
                        <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@_errorZip</MudAlert>
                    }
                </MudCardContent>
                <MudCardActions Class="px-4 pb-4 gap-2 flex-wrap">
                    <MudButton Variant="Variant.Filled" Color="Color.Tertiary" Size="Size.Small"
                               OnClick="ImportarXlsAsync"
                               Disabled="@(_xlsFitxer is null || _carregantXls)"
                               StartIcon="@Icons.Material.Filled.TableChart">
                        @if (_carregantXls) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
                        @Loc["Epss_SubtitleAlumnes"]
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Tertiary" Size="Size.Small"
                               OnClick="ImportarZipAsync"
                               Disabled="@(_zipFitxer is null || _carregantZip)"
                               StartIcon="@Icons.Material.Filled.PhotoLibrary">
                        @if (_carregantZip) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
                        @Loc["Epss_SubtitleFotos"]
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    }

    <MudItem xs="12" md="@(UserState.IsAdmin ? 8 : 12)">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.h6" Style="font-weight:600">@Loc["ClassStudents_ListTitle", _students.Count]</MudText>
            <MudSpacer />
            @if (UserState.IsAdmin && _students.Any())
            {
                <MudCheckBox T="bool" Value="_allSelected" ValueChanged="ToggleSelectAll"
                             Color="Color.Primary" Size="Size.Small"
                             Label="@(_selected.Count == 0 ? Loc["ClassStudents_SelectAll"].Value : Loc["ClassStudents_SelectedCount", _selected.Count].Value)"
                             Style="margin:0" />
            }
        </MudStack>

        @* Barra d'accions massives *@
        @if (UserState.IsAdmin && _selected.Any())
        {
            <MudPaper Elevation="2" Class="pa-2 mb-2 d-flex align-center flex-wrap gap-2"
                      Style="background:var(--mud-palette-primary);border-radius:8px">
                <MudText Typo="Typo.body2" Style="color:white;font-weight:600;flex-shrink:0">
                    @_selected.Count alumne@(_selected.Count != 1 ? "s" : "") seleccionat@(_selected.Count != 1 ? "s" : "")
                </MudText>
                <MudSpacer />
                <MudButton Variant="Variant.Filled" Size="Size.Small" Disabled="_saving"
                           Style="background:rgba(255,255,255,.2);color:white"
                           StartIcon="@Icons.Material.Filled.DriveFileMove"
                           OnClick="BulkMoveAsync">
                    @Loc["ClassStudents_MoveBtn"]
                </MudButton>
                <MudButton Variant="Variant.Filled" Size="Size.Small" Disabled="_saving"
                           Style="background:rgba(255,255,255,.15);color:white;border:1px solid rgba(255,255,255,.5)"
                           StartIcon="@Icons.Material.Filled.Delete"
                           OnClick="BulkDeleteAsync">
                    @Loc["Action_Delete"]
                </MudButton>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               Style="color:white" title="Desseleccionar tots"
                               OnClick="() => _selected.Clear()" />
            </MudPaper>
        }

        <MudDataGrid T="StudentDto" Items="_students" Dense="true" Hover="true"
                     SortMode="SortMode.Single" RowsPerPage="25">
            <PagerContent>
                @if (_students.Count > 25)
                {
                    <MudDataGridPager T="StudentDto" PageSizeOptions="new[]{25,50,100}" />
                }
            </PagerContent>
            <Columns>
                @if (UserState.IsAdmin)
                {
                    <TemplateColumn T="StudentDto" CellStyle="width:32px;padding:0 4px">
                        <HeaderTemplate><span /></HeaderTemplate>
                        <CellTemplate>
                            <MudCheckBox T="bool"
                                         Value="_selected.Contains(context.Item.Id)"
                                         ValueChanged="v => ToggleSelect(context.Item.Id, v)"
                                         Color="Color.Primary" Size="Size.Small" />
                        </CellTemplate>
                    </TemplateColumn>
                }
                <TemplateColumn Title="#">
                    <HeaderTemplate>
                        <MudTooltip Text="Núm. de llista" Placement="Placement.Top">
                            <span style="cursor:help">#</span>
                        </MudTooltip>
                    </HeaderTemplate>
                    <CellTemplate>@context.Item.NumLlista</CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="@Loc["ClassStudents_ColStudent"]">
                    <CellTemplate>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            @if (context.Item.FotoUrl is not null)
                            {
                                <MudAvatar Style="@GetFotoStyle(context.Item.FotoUrl)" Size="Size.Small" />
                            }
                            else
                            {
                                <MudAvatar Style="@GetAvatarStyle(context.Item)" Size="Size.Small">
                                    @GetInitials(context.Item)
                                </MudAvatar>
                            }
                            <span>@context.Item.Cognoms, @context.Item.Nom</span>
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="s => s.Email" Title="@Loc["ClassStudents_ColEmail"]" />
                @if (UserState.IsAdmin)
                {
                    <TemplateColumn Title="" CellStyle="white-space:nowrap">
                        <CellTemplate>
                            <div style="display:flex;align-items:center;gap:0">
                                <MudFileUpload T="IBrowserFile" Accept=".jpg,.jpeg,.png"
                                               FilesChanged="f => UploadFotoAsync(context.Item, f)"
                                               Style="display:inline-flex">
                                    <ActivatorContent>
                                        <MudIconButton Icon="@Icons.Material.Filled.PhotoCamera"
                                                       Size="Size.Small" Color="Color.Primary"
                                                       title="@Loc["Epss_FotoBtn"]" />
                                    </ActivatorContent>
                                </MudFileUpload>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                               Color="Color.Primary" title="Editar"
                                               OnClick="() => StartEdit(context.Item)" />
                                <MudIconButton Icon="@Icons.Material.Filled.DriveFileMove" Size="Size.Small"
                                               Color="Color.Info" title="Moure a una altra classe"
                                               OnClick="() => MoveOneAsync(context.Item)" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error" title="Eliminar"
                                               OnClick="() => DeleteAsync(context.Item)" />
                            </div>
                        </CellTemplate>
                    </TemplateColumn>
                }
            </Columns>
        </MudDataGrid>
    </MudItem>
</MudGrid>

@code {
    [Parameter] public int ClassId { get; set; }

    private ClassDto?         _classe   = null;
    private List<StudentDto>  _students = [];
    private bool _loading = true;
    private bool _saving  = false;

    private int    _numLlista    = 1;
    private string _nom          = "";
    private string _cognoms      = "";
    private string _correu       = "";
    private int    _editStudentId = 0;

    private IBrowserFile?  _importFile;
    private List<string>   _importErrors = [];
    private string?        _importSummary;

    // ── Importació EPSS ───────────────────────────────────────────────────────
    private IBrowserFile? _xlsFitxer;
    private IBrowserFile? _zipFitxer;
    private bool _carregantXls;
    private bool _carregantZip;
    private ImportacioAlumnesResult? _resultXls;
    private ImportacioFotosResult?   _resultZip;
    private string? _errorXls;
    private string? _errorZip;
    private int _fotoVersion; // cache-bust per fotos

    // ── Selecció massiva ──────────────────────────────────────────────────────
    private HashSet<int> _selected = [];
    private bool _allSelected => _students.Count > 0 && _selected.Count == _students.Count;

    private void ToggleSelect(int id, bool add)
    {
        if (add) _selected.Add(id);
        else     _selected.Remove(id);
    }

    private void ToggleSelectAll(bool selectAll)
    {
        if (selectAll) _selected = [.. _students.Select(s => s.Id)];
        else           _selected.Clear();
    }

    private async Task BulkDeleteAsync()
    {
        if (!_selected.Any()) return;
        var ids = _selected.ToList();
        var confirm = await Dialog.ShowMessageBox(Loc["ClassStudents_DeleteTitle"].Value,
            $"S'eliminaran {ids.Count} alumne{(ids.Count != 1 ? "s" : "")} i totes les seves avaluacions. Aquesta acció no es pot desfer.",
            yesText: Loc["Action_Delete"].Value, cancelText: Loc["Action_Cancel"].Value);
        if (confirm != true) return;

        _saving = true;
        Api.SetToken(UserState.Token!);
        int ok = 0, failed = 0;
        foreach (var id in ids)
        {
            var success = await Api.DeleteStudentAsync(ClassId, id);
            if (success) ok++; else failed++;
        }
        Snackbar.Add($"Eliminats: {ok}{(failed > 0 ? $" · Errors: {failed}" : "")}",
            failed > 0 ? Severity.Warning : Severity.Success);
        _selected.Clear();
        await LoadAsync();
        _saving = false;
    }

    // ── Moure alumnes ────────────────────────────────────────────────────────

    private async Task MoveOneAsync(StudentDto s)
    {
        var targetClassId = await PickTargetClassAsync();
        if (targetClassId is null) return;

        _saving = true;
        Api.SetToken(UserState.Token!);
        var moved = await Api.MoveStudentAsync(ClassId, s.Id, targetClassId.Value);
        if (moved is not null)
        {
            Snackbar.Add(Loc["ClassStudents_MoveOk", s.NomComplet].Value, Severity.Success);
            await LoadAsync();
        }
        else Snackbar.Add(Loc["ClassStudents_MoveError"].Value, Severity.Error);
        _saving = false;
    }

    private async Task BulkMoveAsync()
    {
        if (!_selected.Any()) return;
        var targetClassId = await PickTargetClassAsync();
        if (targetClassId is null) return;

        var ids = _selected.ToList();
        _saving = true;
        Api.SetToken(UserState.Token!);
        int ok = 0, failed = 0;
        foreach (var id in ids)
        {
            var moved = await Api.MoveStudentAsync(ClassId, id, targetClassId.Value);
            if (moved is not null) ok++; else failed++;
        }
        Snackbar.Add($"Moguts: {ok}{(failed > 0 ? $" · Errors: {failed}" : "")}",
            failed > 0 ? Severity.Warning : Severity.Success);
        _selected.Clear();
        await LoadAsync();
        _saving = false;
    }

    private async Task<int?> PickTargetClassAsync()
    {
        Api.SetToken(UserState.Token!);
        var classes = await Api.GetClassesAsync() ?? [];
        var others  = classes.Where(c => c.Id != ClassId).ToList();
        if (!others.Any()) { Snackbar.Add(Loc["ClassStudents_NoOtherClasses"].Value, Severity.Info); return null; }

        var opts   = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var param  = new DialogParameters<MoureAlumneDialog> { { d => d.Classes, others } };
        var dialog = await Dialog.ShowAsync<MoureAlumneDialog>(Loc["ClassStudents_MoveTitle"].Value, param, opts);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return null;
        return (int)result.Data!;
    }

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsProfessor) return;
        await LoadAsync();
        _loading = false;
    }

    private async Task LoadAsync()
    {
        Api.SetToken(UserState.Token!);
        _classe   = await Api.GetClassAsync(ClassId);
        _students = await Api.GetStudentsAsync(ClassId) ?? [];
    }

    private async Task AddAsync()
    {
        if (string.IsNullOrWhiteSpace(_nom) || string.IsNullOrWhiteSpace(_cognoms) ||
            string.IsNullOrWhiteSpace(_correu))
        {
            Snackbar.Add(Loc["ClassStudents_FieldsRequired2"].Value, Severity.Warning); return;
        }
        _saving = true;
        Api.SetToken(UserState.Token!);
        var s = await Api.AddStudentAsync(ClassId,
            new CreateStudentRequest(_nom.Trim(), _cognoms.Trim(), _numLlista, _correu.Trim()));
        if (s is not null)
        {
            _students.Add(s);
            _students = [.. _students.OrderBy(x => x.NumLlista)];
            _nom = ""; _cognoms = ""; _correu = ""; _numLlista++;
            Snackbar.Add(Loc["ClassStudents_AddOk", s.NomComplet].Value, Severity.Success);
        }
        else Snackbar.Add(Loc["ClassStudents_AddError"].Value, Severity.Error);
        _saving = false;
    }

    private void StartEdit(StudentDto s)
    {
        _editStudentId = s.Id;
        _nom           = s.Nom;
        _cognoms       = s.Cognoms;
        _numLlista     = s.NumLlista;
        _correu        = s.Email;
    }

    private void CancelEdit()
    {
        _editStudentId = 0;
        _nom = ""; _cognoms = ""; _correu = ""; _numLlista = 1;
    }

    private async Task SaveEditAsync()
    {
        if (string.IsNullOrWhiteSpace(_nom) || string.IsNullOrWhiteSpace(_cognoms) ||
            string.IsNullOrWhiteSpace(_correu))
        {
            Snackbar.Add(Loc["ClassStudents_FieldsRequired2"].Value, Severity.Warning); return;
        }
        _saving = true;
        Api.SetToken(UserState.Token!);
        var updated = await Api.UpdateStudentAsync(ClassId, _editStudentId,
            new UpdateStudentRequest(_nom.Trim(), _cognoms.Trim(), _numLlista, _correu.Trim()));
        if (updated is not null)
        {
            var idx = _students.FindIndex(x => x.Id == _editStudentId);
            if (idx >= 0) _students[idx] = updated;
            _students = [.. _students.OrderBy(x => x.NumLlista)];
            CancelEdit();
            Snackbar.Add(Loc["ClassStudents_UpdateOk", updated.NomComplet].Value, Severity.Success);
        }
        else Snackbar.Add(Loc["ClassStudents_UpdateError"].Value, Severity.Error);
        _saving = false;
    }

    private void OnImportFileSelected(IBrowserFile file)
    {
        _importFile    = file;
        _importErrors  = [];
        _importSummary = null;
    }

    private async Task ImportAsync()
    {
        if (_importFile is null) return;
        _saving      = true;
        _importErrors = [];
        _importSummary = null;

        var ext = System.IO.Path.GetExtension(_importFile.Name).ToLowerInvariant();
        List<CreateStudentRequest> students;
        List<string> parseErrors;

        if (ext is ".xls" or ".xlsx")
            (students, parseErrors) = await ParseXlsAsync();
        else
            (students, parseErrors) = await ParseCsvAsync();

        _importErrors.AddRange(parseErrors);

        if (students.Count == 0)
        {
            _importSummary = parseErrors.Any()
                ? Loc["ClassStudents_FileErrors"].Value
                : Loc["ClassStudents_FileEmpty"].Value;
            _saving = false;
            return;
        }

        Api.SetToken(UserState.Token!);
        var result = await Api.BulkAddStudentsAsync(ClassId, new BulkCreateStudentsRequest(students));
        if (result is not null)
        {
            _importErrors.AddRange(result.Errors);
            var parts = new List<string>();
            if (result.Created > 0) parts.Add($"{result.Created} alumnes creats");
            if (result.Skipped > 0) parts.Add($"{result.Skipped} omesos");
            _importSummary = string.Join(", ", parts) + ".";

            if (result.Created > 0)
                Snackbar.Add(_importSummary, Severity.Success);
            else
                Snackbar.Add(Loc["ClassStudents_NoCreated"].Value, Severity.Warning);
        }
        _importFile = null;
        await LoadAsync();
        _saving = false;
    }

    private async Task<(List<CreateStudentRequest>, List<string>)> ParseCsvAsync()
    {
        var students    = new List<CreateStudentRequest>();
        var errors      = new List<string>();
        var usedNums    = new HashSet<int>();
        var usedEmails  = new HashSet<string>();

        using var stream = _importFile!.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
        using var reader = new System.IO.StreamReader(stream);
        var content = await reader.ReadToEndAsync();
        var lines   = content.Split('\n', StringSplitOptions.RemoveEmptyEntries);

        int lineNum = 0;
        foreach (var rawLine in lines)
        {
            lineNum++;
            var line = rawLine.TrimEnd('\r');
            if (string.IsNullOrWhiteSpace(line)) continue;
            var cols = line.Split(';');
            if (lineNum == 1 && !int.TryParse(cols[0].Trim(), out _)) continue; // capçalera opcional
            if (cols.Length < 4) { errors.Add($"Línia {lineNum}: calen 4 columnes (NumLlista;Nom;Cognoms;Correu)."); continue; }
            if (!int.TryParse(cols[0].Trim(), out var num)) { errors.Add($"Línia {lineNum}: NumLlista invàlid."); continue; }
            var nom    = cols[1].Trim();
            var cog    = cols[2].Trim();
            var correu = cols[3].Trim().ToLower();
            if (string.IsNullOrEmpty(nom) || string.IsNullOrEmpty(cog) || string.IsNullOrEmpty(correu))
            { errors.Add($"Línia {lineNum}: camps buits."); continue; }
            if (!IsValidEmail(correu))
            { errors.Add($"Línia {lineNum}: format de correu invàlid ('{correu}')."); continue; }
            if (!usedNums.Add(num))
            { errors.Add($"Línia {lineNum}: NumLlista {num} duplicat al fitxer."); continue; }
            if (!usedEmails.Add(correu))
            { errors.Add($"Línia {lineNum}: correu '{correu}' duplicat al fitxer."); continue; }
            students.Add(new CreateStudentRequest(nom, cog, num, correu));
        }

        return (students, errors);
    }

    private async Task<(List<CreateStudentRequest>, List<string>)> ParseXlsAsync()
    {
        // Llegim tot l'stream en memòria per poder detectar el format
        using var inputStream = _importFile!.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        var ms = new System.IO.MemoryStream();
        await inputStream.CopyToAsync(ms);
        ms.Position = 0;

        // Molts sistemes escolars web exporten "XLS" que en realitat és una taula HTML.
        // Ho detectem llegint el primer byte: si és '<', és HTML.
        if (ms.Length > 0 && ms.ReadByte() == (byte)'<')
        {
            ms.Position = 0;
            return ParseHtmlTable(ms);
        }

        // Excel binari real (BIFF8 .xls o OpenXML .xlsx)
        ms.Position = 0;
        return ParseBinaryExcel(ms);
    }

    /// <summary>
    /// Parseja la taula HTML exportada per la web de l'escola.
    /// Format: &lt;tr&gt; amb 10 &lt;td&gt;: Num|Cognoms|Nom|DNI|Naix|Baixa|Repetidor|Tel1|Tel2|Email
    /// Encoding: ISO-8859-1 (Windows-1252) — típic de sistemes web antics.
    /// </summary>
    private static (List<CreateStudentRequest>, List<string>) ParseHtmlTable(System.IO.MemoryStream ms)
    {
        var students   = new List<CreateStudentRequest>();
        var errors     = new List<string>();
        var usedNums   = new HashSet<int>();
        var usedEmails = new HashSet<string>();

        // ISO-8859-1 per preservar caràcters accentuats (é, à, ç, ...)
        var encoding = System.Text.Encoding.GetEncoding("iso-8859-1");
        var content  = encoding.GetString(ms.ToArray());

        // Extreure files <tr>...</tr>
        var rows = System.Text.RegularExpressions.Regex.Matches(
            content, @"<tr[^>]*>(.*?)</tr>",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase |
            System.Text.RegularExpressions.RegexOptions.Singleline);

        bool headerSkipped = false;
        int  rowNum        = 0;

        foreach (System.Text.RegularExpressions.Match row in rows)
        {
            rowNum++;
            var rowHtml = row.Groups[1].Value;

            // Primera fila amb <b> = capçalera → saltar
            if (!headerSkipped)
            {
                if (rowHtml.Contains("<b>", StringComparison.OrdinalIgnoreCase))
                    { headerSkipped = true; continue; }
            }

            // Extreure cel·les i eliminar etiquetes HTML interiors
            var cells = System.Text.RegularExpressions.Regex.Matches(
                rowHtml, @"<td[^>]*>(.*?)</td>",
                System.Text.RegularExpressions.RegexOptions.IgnoreCase |
                System.Text.RegularExpressions.RegexOptions.Singleline)
                .Select(m => System.Text.RegularExpressions.Regex
                    .Replace(m.Groups[1].Value, "<[^>]+>", "").Trim())
                .ToList();

            if (cells.Count < 10) continue; // fila incompleta o buida

            var numRaw  = cells[0];
            // Els cognoms tenen espais múltiples de padding → normalitzar
            var cognoms = System.Text.RegularExpressions.Regex.Replace(cells[1].Trim(), @"\s+", " ");
            var nom     = cells[2].Trim();
            var baixa   = cells[5].Trim();
            var email   = cells[9].Trim();

            if (!string.IsNullOrEmpty(baixa)) continue; // alumne de baixa
            if (string.IsNullOrEmpty(numRaw) && string.IsNullOrEmpty(nom)) continue; // fila buida

            if (!int.TryParse(numRaw, out var numLlista))
            { errors.Add($"Fila {rowNum}: número de llista invàlid ('{numRaw}')."); continue; }

            if (string.IsNullOrEmpty(nom) || string.IsNullOrEmpty(cognoms) || string.IsNullOrEmpty(email))
            { errors.Add($"Fila {rowNum}: camps obligatoris buits."); continue; }

            var emailNorm = email.ToLower();
            if (!IsValidEmail(emailNorm))
            { errors.Add($"Fila {rowNum}: format de correu invàlid ('{email}')."); continue; }
            if (!usedNums.Add(numLlista))
            { errors.Add($"Fila {rowNum}: NumLlista {numLlista} duplicat al fitxer."); continue; }
            if (!usedEmails.Add(emailNorm))
            { errors.Add($"Fila {rowNum}: correu '{email}' duplicat al fitxer."); continue; }

            students.Add(new CreateStudentRequest(nom, cognoms, numLlista, emailNorm));
        }

        return (students, errors);
    }

    /// <summary>Parseja Excel binari real (.xls BIFF8 o .xlsx OpenXML) via ExcelDataReader.</summary>
    private static (List<CreateStudentRequest>, List<string>) ParseBinaryExcel(System.IO.MemoryStream ms)
    {
        var students   = new List<CreateStudentRequest>();
        var errors     = new List<string>();
        var usedNums   = new HashSet<int>();
        var usedEmails = new HashSet<string>();

        using var excelReader = ExcelDataReader.ExcelReaderFactory.CreateReader(ms);
        var ds = excelReader.AsDataSet(new ExcelDataReader.ExcelDataSetConfiguration
        {
            ConfigureDataTable = _ => new ExcelDataReader.ExcelDataTableConfiguration { UseHeaderRow = false }
        });

        if (ds.Tables.Count == 0) return (students, errors);
        var sheet = ds.Tables[0];

        // Fila 0: nom classe · Fila 1: buida · Fila 2: capçaleres → dades des de fila 3
        for (int r = 3; r < sheet.Rows.Count; r++)
        {
            var row     = sheet.Rows[r];
            var numRaw  = row[0]?.ToString()?.Trim() ?? "";
            var cognoms = row[1]?.ToString()?.Trim() ?? "";
            var nom     = row[2]?.ToString()?.Trim() ?? "";
            var baixa   = row[5]?.ToString()?.Trim() ?? "";
            var email   = row[9]?.ToString()?.Trim() ?? "";

            if (!string.IsNullOrEmpty(baixa)) continue;
            if (string.IsNullOrEmpty(numRaw) && string.IsNullOrEmpty(nom)) continue;

            int numLlista;
            if (!int.TryParse(numRaw, out numLlista))
            {
                if (double.TryParse(numRaw, System.Globalization.NumberStyles.Any,
                    System.Globalization.CultureInfo.InvariantCulture, out var numD))
                    numLlista = (int)numD;
                else { errors.Add($"Fila {r + 1}: número de llista invàlid ('{numRaw}')."); continue; }
            }

            if (string.IsNullOrEmpty(nom) || string.IsNullOrEmpty(cognoms) || string.IsNullOrEmpty(email))
            { errors.Add($"Fila {r + 1}: camps obligatoris buits."); continue; }

            var emailNorm = email.ToLower();
            if (!IsValidEmail(emailNorm))
            { errors.Add($"Fila {r + 1}: format de correu invàlid ('{email}')."); continue; }
            if (!usedNums.Add(numLlista))
            { errors.Add($"Fila {r + 1}: NumLlista {numLlista} duplicat al fitxer."); continue; }
            if (!usedEmails.Add(emailNorm))
            { errors.Add($"Fila {r + 1}: correu '{email}' duplicat al fitxer."); continue; }

            students.Add(new CreateStudentRequest(nom, cognoms, numLlista, emailNorm));
        }

        return (students, errors);
    }

    private static bool IsValidEmail(string email)
    {
        if (string.IsNullOrWhiteSpace(email)) return false;
        return System.Text.RegularExpressions.Regex.IsMatch(email,
            @"^[^@\s]+@[^@\s]+\.[^@\s]+$",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
    }

    // ── Importació EPSS ───────────────────────────────────────────────────────

    private void OnXlsSeleccionat(IBrowserFile f) { _xlsFitxer = f; _resultXls = null; _errorXls = null; }
    private void OnZipSeleccionat(IBrowserFile f) { _zipFitxer = f; _resultZip = null; _errorZip = null; }

    private async Task ImportarXlsAsync()
    {
        if (_xlsFitxer is null) return;
        _carregantXls = true; _resultXls = null; _errorXls = null;
        try
        {
            Api.SetToken(UserState.Token!);
            using var content = new System.Net.Http.MultipartFormDataContent();
            using var stream  = _xlsFitxer.OpenReadStream(10 * 1024 * 1024);
            content.Add(new System.Net.Http.StreamContent(stream), "fitxer", _xlsFitxer.Name);
            var (result, error) = await Api.ImportarAlumnesXlsAsync(ClassId, content);
            if (error is not null) _errorXls = error;
            else
            {
                _resultXls = result;
                Snackbar.Add(Loc["Epss_ResultatAlumnes",
                    result!.Importats, result.Actualitzats, result.Saltats].Value, Severity.Success);
                await LoadAsync();
            }
        }
        catch (Exception ex) { _errorXls = ex.Message; }
        finally { _carregantXls = false; _xlsFitxer = null; }
    }

    private async Task ImportarZipAsync()
    {
        if (_zipFitxer is null) return;
        _carregantZip = true; _resultZip = null; _errorZip = null;
        try
        {
            Api.SetToken(UserState.Token!);
            using var content = new System.Net.Http.MultipartFormDataContent();
            using var stream  = _zipFitxer.OpenReadStream(100 * 1024 * 1024);
            content.Add(new System.Net.Http.StreamContent(stream), "zip", _zipFitxer.Name);
            var (result, error) = await Api.ImportarFotosExamenAsync(content);
            if (error is not null) _errorZip = error;
            else
            {
                _resultZip = result;
                Snackbar.Add(Loc["Epss_ResultatFotos", result!.Importades].Value, Severity.Success);
                _fotoVersion++;
                await LoadAsync();
            }
        }
        catch (Exception ex) { _errorZip = ex.Message; }
        finally { _carregantZip = false; _zipFitxer = null; }
    }

    private async Task UploadFotoAsync(StudentDto student, IBrowserFile file)
    {
        try
        {
            Api.SetToken(UserState.Token!);
            using var content = new System.Net.Http.MultipartFormDataContent();
            using var stream  = file.OpenReadStream(5 * 1024 * 1024);
            content.Add(new System.Net.Http.StreamContent(stream), "foto", file.Name);
            var url = await Api.UploadStudentFotoAsync(ClassId, student.Id, content);
            if (url is not null)
            {
                _fotoVersion++;
                var idx = _students.FindIndex(s => s.Id == student.Id);
                if (idx >= 0) _students[idx] = _students[idx] with { FotoUrl = url };
                Snackbar.Add(Loc["Epss_FotoOk"].Value, Severity.Success);
            }
            else Snackbar.Add(Loc["Epss_FotoError"].Value, Severity.Error);
        }
        catch (Exception ex) { Snackbar.Add($"{Loc["Epss_FotoError"]}: {ex.Message}", Severity.Error); }
    }

    // ── Avatars ──────────────────────────────────────────────────────────────

    private static string GetInitials(StudentDto s)
    {
        var cog = s.Cognoms?.TrimStart().FirstOrDefault();
        var nom = s.Nom?.TrimStart().FirstOrDefault();
        return $"{cog}{nom}".ToUpper();
    }

    private static readonly string[] _avatarColors =
        ["#CC0000", "#1e293b", "#0891b2", "#059669", "#7c3aed", "#d97706", "#db2777"];

    private string GetFotoStyle(string url) =>
        $"background-image:url('{url}?v={_fotoVersion}');background-size:cover;background-position:center;width:28px;height:28px;min-width:28px";

    private static string GetAvatarStyle(StudentDto s)
    {
        var color = _avatarColors[s.NumLlista % _avatarColors.Length];
        return $"background:{color};color:white;font-size:0.68rem;width:28px;height:28px;min-width:28px";
    }

    private async Task DeleteAsync(StudentDto s)
    {
        if (!await DeleteWithUndoAsync($"Eliminant «{s.NomComplet}»...")) return;
        Api.SetToken(UserState.Token!);
        await Api.DeleteStudentAsync(ClassId, s.Id);
        _students.RemoveAll(x => x.Id == s.Id);
        _selected.Remove(s.Id);
        Snackbar.Add($"Alumne «{s.NomComplet}» eliminat.", Severity.Success);
    }

    private async Task<bool> DeleteWithUndoAsync(string msg)
    {
        var cancelled = false;
        var cts = new CancellationTokenSource();
        Snackbar.Add(msg, Severity.Warning, cfg =>
        {
            cfg.Action               = "Desfer";
            cfg.ActionColor          = Color.Warning;
            cfg.ActionVariant        = Variant.Text;
            cfg.OnClick              = _ => { cancelled = true; cts.Cancel(); return Task.CompletedTask; };
            cfg.VisibleStateDuration = 5000;
        });
        try { await Task.Delay(5500, cts.Token); } catch (OperationCanceledException) { }
        if (cancelled) Snackbar.Add("Eliminació cancel·lada.", Severity.Info);
        return !cancelled;
    }

    private async Task ExportCsvAsync()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("NumLlista;Nom;Cognoms;Correu");
        foreach (var s in _students.OrderBy(x => x.NumLlista))
            sb.AppendLine($"{s.NumLlista};{s.Nom};{s.Cognoms};{s.Email}");
        var fileName = $"alumnes-{_classe?.Name ?? ClassId.ToString()}.csv".Replace(" ", "_");
        await JS.InvokeVoidAsync("eval", $@"
            (function(){{
                var blob = new Blob([{System.Text.Json.JsonSerializer.Serialize(sb.ToString())}],
                    {{type:'text/csv;charset=utf-8;'}});
                var url = URL.createObjectURL(blob);
                var a = document.createElement('a');
                a.href = url; a.download = {System.Text.Json.JsonSerializer.Serialize(fileName)};
                document.body.appendChild(a); a.click();
                document.body.removeChild(a); URL.revokeObjectURL(url);
            }})()");
    }
