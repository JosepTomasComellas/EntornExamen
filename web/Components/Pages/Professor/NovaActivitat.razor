@page "/professor/nova-activitat"
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResources> Loc

<PageTitle>Nova activitat – Entorn d'Examens</PageTitle>
@if (!UserState.IsProfessor) { Nav.NavigateTo("/"); return; }

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6">
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Href="/professor/dashboard"
               Variant="Variant.Text" Color="Color.Default">@Loc["Nav_Dashboard"]</MudButton>
    <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
    <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Primary" Class="mr-1" />
    <MudText Typo="Typo.h5" Style="font-weight:700">@Loc["NewAct_Title"]</MudText>
</MudStack>

<MudContainer MaxWidth="MaxWidth.Small">
    <MudCard Elevation="3">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @Loc["NewAct_Info"]
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <!-- Selector de plantilla (opcional) -->
            @if (_templates.Any())
            {
                <MudSelect T="int" Value="_templateId" Label="@Loc["NewAct_FromTemplate"]"
                           Variant="Variant.Outlined" Class="mb-4"
                           Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                           ValueChanged="OnTemplateChanged">
                    <MudSelectItem T="int" Value="0">@Loc["NewAct_NoTemplate"]</MudSelectItem>
                    @foreach (var t in _templates)
                    {
                        <MudSelectItem T="int" Value="@t.Id">
                            @t.Name
                            @if (!string.IsNullOrWhiteSpace(t.ProfessorName))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-1">
                                    (@t.ProfessorName)
                                </MudText>
                            }
                        </MudSelectItem>
                    }
                </MudSelect>
            }

            <MudSelect T="int" Value="_classId" Label="@Loc["Label_Class"]" Variant="Variant.Outlined"
                       Class="mb-4" Adornment="Adornment.Start"
                       AdornmentIcon="@Icons.Material.Filled.Class"
                       ValueChanged="OnClassChanged">
                <MudSelectItem T="int" Value="0">@Loc["NewAct_SelectClass"]</MudSelectItem>
                @foreach (var c in _classes)
                {
                    <MudSelectItem T="int" Value="@c.Id">
                        @c.Name @(c.AcademicYear is not null ? $"({c.AcademicYear})" : "")
                    </MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="int" @bind-Value="_moduleId" Label="@Loc["Label_Module"]" Variant="Variant.Outlined"
                       Class="mb-4" Adornment="Adornment.Start"
                       Disabled="_classId == 0 || _loadingModules"
                       AdornmentIcon="@Icons.Material.Filled.MenuBook">
                <MudSelectItem T="int" Value="0">@Loc["NewAct_SelectModule"]</MudSelectItem>
                @foreach (var m in _modules)
                {
                    <MudSelectItem T="int" Value="@m.Id">
                        @m.Code – @m.Name
                    </MudSelectItem>
                }
            </MudSelect>
            @if (_classId > 0 && !_loadingModules && _modules.Count == 0)
            {
                <MudAlert Severity="Severity.Warning" Class="mb-3" Dense="true">
                    @Loc["NewAct_NoModules"]
                    <MudLink Href="@($"/professor/moduls/{_classId}")">@Loc["NewAct_AddModules"]</MudLink>
                </MudAlert>
            }

            <MudTextField @bind-Value="_nom" Label="@Loc["NewAct_ActivityName"]" Variant="Variant.Outlined"
                          Class="mb-4" Immediate="true" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Assignment" />
            <MudTextField @bind-Value="_desc" Label="@Loc["NewAct_Description"]" Variant="Variant.Outlined"
                          Lines="3" Immediate="true" />
        </MudCardContent>
        <MudCardActions Class="px-4 pb-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                       Size="Size.Large" OnClick="CreateAsync" Disabled="_saving"
                       StartIcon="@Icons.Material.Filled.AddCircle">
                @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                @Loc["NewAct_CreateBtn"]
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    [SupplyParameterFromQuery] public int ModuleId { get; set; }

    private List<ClassDto>            _classes   = [];
    private List<ModuleDto>           _modules   = [];
    private List<ActivityTemplateDto> _templates = [];
    private int    _classId        = 0;
    private int    _moduleId       = 0;
    private int    _templateId     = 0;
    private string _nom            = "";
    private string _desc           = "";
    private bool   _saving         = false;
    private bool   _loadingModules = false;

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsProfessor) return;
        Api.SetToken(UserState.Token!);
        var classTask    = Api.GetClassesAsync();
        var templateTask = Api.GetTemplatesAsync();
        await Task.WhenAll(classTask, templateTask);
        _classes   = classTask.Result    ?? [];
        _templates = templateTask.Result ?? [];

        if (ModuleId > 0)
        {
            foreach (var c in _classes)
            {
                var mods = await Api.GetModulesAsync(c.Id) ?? [];
                if (mods.Any(m => m.Id == ModuleId))
                {
                    _classId = c.Id;
                    _modules = mods;
                    _moduleId = ModuleId;
                    break;
                }
            }
        }
    }

    private async Task OnClassChanged(int classId)
    {
        _classId  = classId;
        _moduleId = 0;
        _modules  = [];
        if (classId <= 0) return;
        _loadingModules = true;
        Api.SetToken(UserState.Token!);
        _modules = await Api.GetModulesAsync(classId) ?? [];
        _loadingModules = false;
    }

    private void OnTemplateChanged(int templateId)
    {
        _templateId = templateId;
        if (templateId <= 0) return;
        var t = _templates.FirstOrDefault(x => x.Id == templateId);
        if (t is null) return;
        _nom  = t.Name;
        _desc = t.Description ?? "";
    }

    private async Task CreateAsync()
    {
        if (_moduleId <= 0 || string.IsNullOrWhiteSpace(_nom))
        {
            Snackbar.Add(Loc["NewAct_SelectModName"], Severity.Warning);
            return;
        }
        _saving = true;
        Api.SetToken(UserState.Token!);
        var act = await Api.CreateActivityAsync(new CreateActivityRequest(
            _moduleId, _nom.Trim(),
            string.IsNullOrWhiteSpace(_desc) ? null : _desc.Trim()));
        _saving = false;
        if (act is not null)
        {
            Snackbar.Add(Loc["NewAct_CreatedMsg", act.Name], Severity.Success);
            Nav.NavigateTo($"/professor/grups/{act.Id}");
        }
        else Snackbar.Add(Loc["NewAct_CreateError"], Severity.Error);
    }
}
