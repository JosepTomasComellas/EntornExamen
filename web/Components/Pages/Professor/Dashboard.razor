@page "/professor/dashboard"
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> Loc

<PageTitle>Tauler del Professor – AutoCo</PageTitle>
@if (!UserState.IsProfessor) { Nav.NavigateTo("/"); return; }

<!-- Capçalera -->
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Wrap="Wrap.Wrap">
    <MudText Typo="Typo.h5">@Loc["Dash_Welcome", UserState.NomComplet ?? ""]</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               Href="/professor/nova-activitat">
        @Loc["Dash_NewActivity"]
    </MudButton>
    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Class"
               Href="/professor/classes">
        @Loc["Dash_ManageClasses"]
    </MudButton>
    @if (UserState.IsAdmin)
    {
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.People"
                   Href="/admin/professors">
            @Loc["Dash_Teachers"]
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.CloudDone"
                   Href="/admin/backup">
            @Loc["Dash_Backups"]
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.BarChart"
                   Href="/admin/estadistiques">
            Estadístiques
        </MudButton>
    }
    <MudButton Variant="Variant.Filled" Color="Color.Error"
               StartIcon="@Icons.Material.Filled.Monitor"
               Href="/professor/examen">
        Entorn Examen
    </MudButton>
    @if (UserState.IsAdmin)
    {
        <MudButton Variant="Variant.Outlined" Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.Devices"
                   Href="/admin/examen-macs">
            @Loc["Dash_ExamenMacs"]
        </MudButton>
    }
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (!_activities.Any())
{
    <MudAlert Severity="Severity.Info">
        @Loc["Dash_NoActivities"]
    </MudAlert>
}
else
{
    <!-- Estadístiques ràpides -->
    <MudGrid Class="mb-4" Spacing="2">
        <MudItem xs="6" sm="4">
            <MudPaper Elevation="1" Class="pa-3 text-center">
                <MudIcon Icon="@Icons.Material.Filled.Class" Color="Color.Secondary" Size="Size.Small" />
                <MudText Typo="Typo.h5" Color="Color.Secondary" Style="font-weight:700">@_classesDtos.Count</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Dash_StatClasses"]</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4">
            <MudPaper Elevation="1" Class="pa-3 text-center">
                <MudIcon Icon="@Icons.Material.Filled.MenuBook" Color="Color.Secondary" Size="Size.Small" />
                <MudText Typo="Typo.h5" Color="Color.Secondary" Style="font-weight:700">@_moduls.Count</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Dash_StatModuls"]</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4">
            <MudPaper Elevation="1" Class="pa-3 text-center">
                <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Info" Size="Size.Small" />
                <MudText Typo="Typo.h5" Color="Color.Info" Style="font-weight:700">@_totalAlumnes</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Dash_StatStudents"]</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4">
            <MudPaper Elevation="1" Class="pa-3 text-center">
                <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Primary" Size="Size.Small" />
                <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight:700">@_activities.Count</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Dash_StatActivities"]</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4">
            <MudPaper Elevation="1" Class="pa-3 text-center">
                <MudIcon Icon="@Icons.Material.Filled.LockOpen" Color="Color.Success" Size="Size.Small" />
                <MudText Typo="Typo.h5" Color="Color.Success" Style="font-weight:700">@_activities.Count(a => a.IsOpen)</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Dash_OpenNow"]</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4">
            <MudPaper Elevation="1" Class="pa-3 text-center">
                <MudIcon Icon="@Icons.Material.Filled.Group" Color="Color.Warning" Size="Size.Small" />
                <MudText Typo="Typo.h5" Color="Color.Warning" Style="font-weight:700">@_activities.Sum(a => a.NumGroups)</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Dash_StatGroups"]</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- Filtres -->
    <MudGrid Class="mb-4" Spacing="2">
        <MudItem xs="12" sm="6" md="3">
            <MudTextField @bind-Value="_cerca" Label="@Loc["Dash_SearchActivity"]" Variant="Variant.Outlined"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Clearable="true" Immediate="true" Margin="Margin.Dense" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudSelect T="int" @bind-Value="_classeId" Label="@Loc["Label_Class"]" AnchorOrigin="Origin.BottomCenter"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                <MudSelectItem T="int" Value="0">@Loc["Dash_AllClasses"]</MudSelectItem>
                @foreach (var c in _classes)
                {
                    <MudSelectItem T="int" Value="@c.Key">@c.Value</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudSelect T="int" @bind-Value="_modulId" Label="@Loc["Label_Module"]" AnchorOrigin="Origin.BottomCenter"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                <MudSelectItem T="int" Value="0">@Loc["Dash_AllModules"]</MudSelectItem>
                @foreach (var m in _moduls)
                {
                    <MudSelectItem T="int" Value="@m.Key">@m.Value</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="3" Class="d-flex align-center gap-3">
            <MudSwitch @bind-Value="_nomesObertes" Color="Color.Success" Label="@Loc["Dash_OnlyOpen"]" Size="Size.Small" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                @Loc["Dash_CountOf", _filtrades.Count, _activities.Count]
            </MudText>
        </MudItem>
    </MudGrid>

    @if (!_obertes.Any() && !_tancades.Any())
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            @Loc["Dash_NoMatch"]
        </MudAlert>
    }

    @if (_obertes.Any())
    {
        <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight:600">
            <MudIcon Icon="@Icons.Material.Filled.LockOpen" Size="Size.Small"
                     Color="Color.Success" Class="mr-1" Style="vertical-align:middle" />
            @Loc["Dash_OpenActivities", _obertes.Count]
        </MudText>
        <MudGrid Class="mb-6">
            @foreach (var act in _obertes)
            {
                <MudItem xs="12" sm="6" lg="4">
                    <ActivityCard Act="act" OnUpdated="OnActUpdated" OnDeleted="OnActDeleted" />
                </MudItem>
            }
        </MudGrid>
    }

    @if (_tancades.Any())
    {
        <MudText Typo="Typo.subtitle1" Class="mb-3"
                 Style="font-weight:600;color:var(--mud-palette-text-secondary)">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small"
                     Color="Color.Default" Class="mr-1" Style="vertical-align:middle" />
            @Loc["Dash_ClosedActivities", _tancades.Count]
        </MudText>
        <MudGrid>
            @foreach (var act in _tancades)
            {
                <MudItem xs="12" sm="6" lg="4">
                    <ActivityCard Act="act" OnUpdated="OnActUpdated" OnDeleted="OnActDeleted" />
                </MudItem>
            }
        </MudGrid>
    }
}

@code {
    private List<ActivityDto> _activities = [];
    private List<ClassDto>    _classesDtos = [];
    private bool _loading = true;

    private string _cerca        = "";
    private int    _classeId     = 0;
    private int    _modulId      = 0;
    private bool   _nomesObertes = false;

    private Dictionary<int, string> _classes = [];
    private Dictionary<int, string> _moduls  = [];
    private int _totalAlumnes => _classesDtos.Sum(c => c.NumStudents);

    private List<ActivityDto> _obertes  => _filtrades.Where(a =>  a.IsOpen).ToList();
    private List<ActivityDto> _tancades => _filtrades.Where(a => !a.IsOpen).ToList();

    private List<ActivityDto> _filtrades => _activities
        .Where(a => (string.IsNullOrWhiteSpace(_cerca) ||
                     a.Name.Contains(_cerca, StringComparison.OrdinalIgnoreCase) ||
                     (a.Description?.Contains(_cerca, StringComparison.OrdinalIgnoreCase) ?? false))
                 && (_classeId == 0 || a.ClassId == _classeId)
                 && (_modulId  == 0 || a.ModuleId == _modulId)
                 && (!_nomesObertes || a.IsOpen))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsProfessor) return;
        Api.SetToken(UserState.Token!);
        var activitiesTask = Api.GetActivitiesAsync();
        var classesTask    = Api.GetClassesAsync();
        await Task.WhenAll(activitiesTask, classesTask);
        _activities   = activitiesTask.Result ?? [];
        _classesDtos  = classesTask.Result    ?? [];
        _classes = _activities
            .GroupBy(a => a.ClassId)
            .ToDictionary(g => g.Key, g => g.First().ClassName +
                (g.First().ClassAcademicYear is not null ? $" ({g.First().ClassAcademicYear})" : ""));
        _moduls = _activities
            .GroupBy(a => a.ModuleId)
            .ToDictionary(g => g.Key, g => $"{g.First().ModuleCode} – {g.First().ModuleName}");
        _loading = false;
    }

    private void OnActUpdated(ActivityDto updated)
    {
        var idx = _activities.FindIndex(a => a.Id == updated.Id);
        if (idx >= 0)
            _activities[idx] = updated;
        else
            _activities.Insert(0, updated); // activitat duplicada nova
    }

    private void OnActDeleted(ActivityDto deleted)
    {
        _activities.RemoveAll(a => a.Id == deleted.Id);
    }
}
