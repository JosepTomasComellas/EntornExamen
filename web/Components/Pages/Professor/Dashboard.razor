@page "/professor/dashboard"
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> Loc

<PageTitle>Tauler del Professor – Entorn d'Examens</PageTitle>
@if (!UserState.IsProfessor) { Nav.NavigateTo("/"); return; }

<!-- Capçalera -->
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Wrap="Wrap.Wrap">
    <MudText Typo="Typo.h5">@Loc["Dash_Welcome", UserState.NomComplet ?? ""]</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Class"
               Href="/professor/classes">
        @Loc["Dash_ManageClasses"]
    </MudButton>
    @if (UserState.IsAdmin)
    {
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.People"
                   Href="/admin/professors">
            @Loc["Dash_Teachers"]
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.CloudDone"
                   Href="/admin/backup">
            @Loc["Dash_Backups"]
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.BarChart"
                   Href="/admin/estadistiques">
            Estadístiques
        </MudButton>
    }
    <MudButton Variant="Variant.Filled" Color="Color.Error"
               StartIcon="@Icons.Material.Filled.Monitor"
               Href="/professor/examen">
        Entorn Examen
    </MudButton>
    @if (UserState.IsAdmin)
    {
        <MudButton Variant="Variant.Outlined" Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.Devices"
                   Href="/admin/examen-macs">
            @Loc["Dash_ExamenMacs"]
        </MudButton>
    }
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else
{
    <!-- KPI ràpids -->
    <MudGrid Class="mb-6" Spacing="2">
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="1" Class="pa-3 text-center">
                <MudIcon Icon="@Icons.Material.Filled.Class" Color="Color.Secondary" Size="Size.Small" />
                <MudText Typo="Typo.h5" Color="Color.Secondary" Style="font-weight:700">@_classesDtos.Count</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Dash_StatClasses"]</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="1" Class="pa-3 text-center">
                <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Info" Size="Size.Small" />
                <MudText Typo="Typo.h5" Color="Color.Info" Style="font-weight:700">@_totalAlumnes</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Dash_StatStudents"]</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="1" Class="pa-3 text-center">
                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Color="Color.Success" Size="Size.Small" />
                <MudText Typo="Typo.h5" Color="Color.Success" Style="font-weight:700">@_sessionsObertes</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Sessions obertes</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="1" Class="pa-3 text-center">
                <MudIcon Icon="@Icons.Material.Filled.History" Color="Color.Default" Size="Size.Small" />
                <MudText Typo="Typo.h5" Style="font-weight:700">@_sessions.Count</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Sessions totals</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- Accés ràpid a l'Entorn d'Examen -->
    <MudPaper Elevation="2" Class="pa-4 mb-4"
              Style="border-left:4px solid var(--mud-palette-error)">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudIcon Icon="@Icons.Material.Filled.Monitor" Color="Color.Error" Size="Size.Large" />
            <MudStack Spacing="0">
                <MudText Typo="Typo.subtitle1" Style="font-weight:700">Entorn d'Examen</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Gestiona sessions d'examen, visualitza connexions en temps real i controla els alumnes connectats.
                </MudText>
            </MudStack>
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.OpenInNew"
                       Href="/professor/examen">
                Obrir
            </MudButton>
        </MudStack>
    </MudPaper>

    <!-- Últimes sessions -->
    @if (_sessions.Any())
    {
        <MudText Typo="Typo.subtitle1" Style="font-weight:600;margin-bottom:.75rem">
            Sessions recents
        </MudText>
        <MudPaper Elevation="1" Class="pa-0">
            <MudTable Items="_sessions.Take(5)" Dense="true" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Títol</MudTh>
                    <MudTh>Estat</MudTh>
                    <MudTh>Creada</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@(context.Titol ?? "(sense títol)")</MudTd>
                    <MudTd>
                        @if (context.Activa)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Oberta</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Tancada</MudChip>
                        }
                    </MudTd>
                    <MudTd>@context.IniciadaAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
}

@code {
    private List<ClassDto>          _classesDtos = [];
    private List<SessioExamenDto>   _sessions    = [];
    private bool _loading = true;

    private int _totalAlumnes   => _classesDtos.Sum(c => c.NumStudents);
    private int _sessionsObertes => _sessions.Count(s => s.Activa);

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsProfessor) return;
        Api.SetToken(UserState.Token!);
        var classesTask  = Api.GetClassesAsync();
        var sessionsTask = Api.GetExamenSessionsAsync();
        await Task.WhenAll(classesTask, sessionsTask);
        _classesDtos = classesTask.Result  ?? [];
        _sessions    = sessionsTask.Result ?? [];
        _sessions    = [.. _sessions.OrderByDescending(s => s.IniciadaAt)];
        _loading     = false;
    }
}
