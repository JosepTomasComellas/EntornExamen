@page "/professor/examen"
@rendermode InteractiveServer
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav
@inject ExamenNotificationService ExamenNotif
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResources> Loc
@inject IConfiguration Config
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>@Loc["Examen_Title"] – Entorn d'Examens</PageTitle>

@if (!UserState.IsProfessor) { Nav.NavigateTo("/"); return; }

<!-- Barra de control -->
<MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
               Href="/professor/dashboard"
               Variant="Variant.Text" Color="Color.Default">
        @Loc["Nav_Dashboard"]
    </MudButton>
    <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
    <MudIcon Icon="@Icons.Material.Filled.Monitor" Color="Color.Error" Class="mr-1" />
    <MudText Typo="Typo.h5"><strong>@Loc["Examen_Title"]</strong></MudText>
    <MudSpacer />

    @if (_sessio is not null)
    {
        <MudChip T="string" Color="@(_sessio.Activa ? Color.Success : Color.Default)"
                 Size="Size.Small">
            @(_sessio.Activa ? Loc["Examen_SessionActive"].Value : Loc["Examen_SessionClosed"].Value)
        </MudChip>
        <MudText Typo="Typo.body2">
            @Loc["Examen_Connected", _connectats, _sessio.TotalAlumnes]
        </MudText>
        <MudProgressLinear
            Value="@(_sessio.TotalAlumnes > 0 ? _connectats * 100.0 / _sessio.TotalAlumnes : 0)"
            Color="Color.Success" Rounded="true" Size="Size.Small"
            Style="min-width:120px;max-width:200px" />
    }

    <!-- Botons acció -->
    @if (_sessio is null || (!_sessio.Activa && _sessions.All(s => !s.Activa)))
    {
        <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.PlayArrow"
                   OnClick="() => _mostrarDialegNovaSessio = true">
            @Loc["Examen_StartSession"]
        </MudButton>
    }
    else if (_sessio?.Activa == true)
    {
        <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Stop"
                   OnClick="TancarSessio">
            @Loc["Examen_CloseSession"]
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Campaign"
                   OnClick="() => _mostrarDialegMissatge = true">
            @Loc["Examen_SendMessage"]
        </MudButton>
    }
    else if (_sessio is not null && !_sessio.Activa)
    {
        <MudButton Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.PlayCircle"
                   OnClick="ReobrirSessio">
            @Loc["Examen_ReopenSession"]
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.PlayArrow"
                   OnClick="() => _mostrarDialegNovaSessio = true">
            @Loc["Examen_StartSession"]
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.DeleteForever"
                   OnClick="() => { _sessioAEliminar = _sessio; _confirmarEliminarSessio = true; }">
            Eliminar sessió
        </MudButton>
    }

    @if (_sessio is not null)
    {
        <MudButton Variant="Variant.Outlined" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Download"
                   OnClick="ExportarCsv">
            @Loc["Examen_ExportCsv"]
        </MudButton>
        <MudButton Variant="Variant.Outlined" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Fullscreen"
                   OnClick="EntrarModePresentacio">
            @Loc["Examen_Presentation"]
        </MudButton>
    }
</MudStack>

<!-- Llista de sessions recents -->
@if (_sessions.Count > 0)
{
    <MudPaper Elevation="1" Class="mb-4" Style="border-radius:8px;overflow:hidden">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="px-3 py-2"
                  Style="border-bottom:1px solid var(--mud-palette-divider)">
            <MudIcon Icon="@Icons.Material.Filled.History"
                     Size="Size.Small" Color="Color.Secondary" Class="mr-1" />
            <MudText Typo="Typo.caption"
                     Style="font-weight:700;text-transform:uppercase;letter-spacing:.05em">
                Sessions recents
            </MudText>
            <MudSpacer />
            <MudIconButton Icon="@(_mostrarSessions ? Icons.Material.Filled.ExpandLess
                                                    : Icons.Material.Filled.ExpandMore)"
                           Size="Size.Small"
                           OnClick="@(() => _mostrarSessions = !_mostrarSessions)" />
        </MudStack>
        @if (_mostrarSessions)
        {
            @foreach (var s in _sessions.OrderByDescending(s => s.IniciadaAt))
            {
                var seleccionada = s.Id == _sessioId;
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"
                          Class="px-3 py-2"
                          Style="@($"border-bottom:1px solid var(--mud-palette-divider);{(seleccionada ? "background:rgba(var(--mud-palette-primary-rgb),.08)" : "")}")">
                    <MudChip T="string" Size="Size.Small"
                             Color="@(s.Activa ? Color.Success : Color.Default)"
                             Class="ma-0">
                        @(s.Activa ? "Activa" : "Tancada")
                    </MudChip>
                    <MudStack Spacing="0" Style="flex:1;min-width:0">
                        <MudText Typo="Typo.body2"
                                 Style="@(seleccionada ? "font-weight:700" : "")">
                            @s.ClassName — @(s.Titol ?? "Sense títol")
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @s.IniciadaAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            @if (s.TancadaAt.HasValue)
                            {
                                <text> → @s.TancadaAt.Value.ToLocalTime().ToString("HH:mm")</text>
                            }
                        </MudText>
                    </MudStack>
                    @if (!seleccionada)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                       Title="Seleccionar sessió" Size="Size.Small"
                                       OnClick="@(() => SeleccionarSessio(s.Id))" />
                    }
                    @if (!s.Activa)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.DeleteForever"
                                       Color="Color.Error" Title="Eliminar sessió"
                                       Size="Size.Small"
                                       OnClick="@(() => { _sessioAEliminar = s; _confirmarEliminarSessio = true; })" />
                    }
                </MudStack>
            }
        }
    </MudPaper>
}

<!-- Sense sessió -->
@if (_sessio is null && !_carregant)
{
    <MudAlert Severity="Severity.Info">@Loc["Examen_NoSession"]</MudAlert>
}

<!-- Barra de filtres -->
@if (_alumnes.Count > 0)
{
    <MudGrid Spacing="2" Class="mb-3">
        <MudItem xs="12" sm="6" md="4">
            <MudTextField @bind-Value="_cerca" Label="@Loc["Examen_Search"]"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Clearable="true" Immediate="true" />
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudSelect T="EstatConnexioDto?" @bind-Value="_filtreEstat"
                       Label="@Loc["Examen_FilterStatus"]"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                <MudSelectItem T="EstatConnexioDto?" Value="@((EstatConnexioDto?)null)">
                    @Loc["Examen_AllStatuses"]
                </MudSelectItem>
                <MudSelectItem T="EstatConnexioDto?" Value="@((EstatConnexioDto?)EstatConnexioDto.Connectat)">
                    @Loc["Examen_Status_Connectat"]
                </MudSelectItem>
                <MudSelectItem T="EstatConnexioDto?" Value="@((EstatConnexioDto?)EstatConnexioDto.SenseCheckin)">
                    @Loc["Examen_Status_SenseCheckin"]
                </MudSelectItem>
                <MudSelectItem T="EstatConnexioDto?" Value="@((EstatConnexioDto?)EstatConnexioDto.Desconnectat)">
                    @Loc["Examen_Status_Desconnectat"]
                </MudSelectItem>
                <MudSelectItem T="EstatConnexioDto?" Value="@((EstatConnexioDto?)EstatConnexioDto.NoConnectat)">
                    @Loc["Examen_Status_NoConnectat"]
                </MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="12" md="4" Class="d-flex align-center">
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                @_alumnesFiltrats.Count() / @_alumnes.Count
            </MudText>
        </MudItem>
    </MudGrid>
}

<!-- Layout principal: graella + pannell detall al costat -->
<MudGrid Spacing="3">

    <!-- Columna graella -->
    <MudItem xs="12" md="@(_mostraDetall ? 9 : 12)">

        @if (_alumnes.Count > 0)
        {
            <MudGrid Spacing="2" id="graella-examen">
                @foreach (var a in _alumnesFiltrats)
                {
                    var color     = EstatColor(a.Estat);
                    var seleccionat = _alumneSeleccionat?.MacAddress == a.MacAddress;
                    var textColor = a.Estat == EstatConnexioDto.Connectat    ? "color:#15803d" :
                                    a.Estat == EstatConnexioDto.SenseCheckin ? "color:#b45309" :
                                    a.Estat == EstatConnexioDto.Desconnectat ? "color:#dc2626" :
                                                                               "color:#6b7280";

                    <MudItem xs="12" sm="6" md="@(_mostraDetall ? 6 : 4)" lg="@(_mostraDetall ? 6 : 3)">
                        <MudCard Elevation="@(seleccionat ? 6 : 2)"
                                 Style="@($"border-left:4px solid {color};cursor:pointer;{(seleccionat ? $"outline:2px solid {color};outline-offset:2px" : "")}")"
                                 @onclick="() => SeleccionarAlumne(a)">
                            <MudCardContent Class="pa-3">
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    @if (a.FotoUrl is not null)
                                    {
                                        <MudAvatar Style="width:48px;height:48px">
                                            <MudImage Src="@a.FotoUrl"
                                                      Style="width:48px;height:48px;object-fit:cover" />
                                        </MudAvatar>
                                    }
                                    else
                                    {
                                        <MudAvatar Style="@($"width:48px;height:48px;background:{color}20;color:{color}")">
                                            @((a.Nom?[..1] ?? "?") + (a.Cognoms?[..1] ?? ""))
                                        </MudAvatar>
                                    }
                                    <MudStack Spacing="0" Style="min-width:0;flex:1">
                                        <MudText Typo="Typo.body2"
                                                 Style="font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                                            @(a.Nom is not null ? $"{a.Cognoms}, {a.Nom}" : a.MacAddress)
                                        </MudText>
                                        <MudText Typo="Typo.caption"
                                                 Style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                                            @(a.Email ?? a.IpAssignada ?? "—")
                                        </MudText>
                                    </MudStack>
                                </MudStack>

                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="mt-2">
                                    <div style="@($"width:10px;height:10px;border-radius:50%;background:{color}")"></div>
                                    <MudText Typo="Typo.caption" Style="@($"{textColor};font-weight:600")">
                                        @EstatText(a.Estat)
                                        @if (a.Estat == EstatConnexioDto.Desconnectat && _sortideVoluntaries.Contains(a.MacAddress))
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.ExitToApp"
                                                     Size="Size.Small" Color="Color.Warning"
                                                     title="Ha sortit voluntàriament"
                                                     Style="vertical-align:middle;margin-left:2px" />
                                        }
                                    </MudText>
                                    @if (a.IpAssignada is not null)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            · @a.IpAssignada
                                        </MudText>
                                    }
                                        @if (a.DnsRecents.Any(d => d.EsExterna))
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Warning"
                                                 Color="Color.Warning" Size="Size.Small"
                                                 title="DNS externes detectades"
                                                 Style="animation:pulse-warning 1s infinite" />
                                    }
                                    @if (!EsIpDhcp(a.IpAssignada))
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.WifiOff"
                                                 Color="Color.Error" Size="Size.Small"
                                                 title="IP fora del rang DHCP (192.168.100.x)"
                                                 Class="ml-auto" />
                                    }
                                </MudStack>

                                @if (a.UltimCheckinAt.HasValue)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Check-in: @a.UltimCheckinAt.Value.ToLocalTime().ToString("HH:mm:ss")
                                        @if (a.Estat is EstatConnexioDto.Connectat or EstatConnexioDto.SenseCheckin)
                                        {
                                            <text> — <span style="@ElapsedStyle(a.UltimCheckinAt.Value)">@FormatElapsed((int)(_ara - a.UltimCheckinAt.Value).TotalSeconds)</span></text>
                                        }
                                    </MudText>
                                }
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }

        <!-- Historial de connexions -->
        <MudPaper Elevation="2" Class="pa-3 mt-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3"
                      Wrap="Wrap.Wrap">
                <MudText Typo="Typo.subtitle2"><strong>Historial de connexions</strong></MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_cercaHistoric"
                              Label="Cerca per alumne o event..."
                              Variant="Variant.Text" Margin="Margin.Dense"
                              Style="max-width:240px"
                              Clearable="true" Immediate="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search" />
                @if (_alertes.Count > 0)
                {
                    <MudButton Variant="Variant.Text" Size="Size.Small"
                               OnClick="NetejarHistoric">
                        @Loc["Examen_ClearAlerts"]
                    </MudButton>
                }
            </MudStack>
            @{
                var historicFiltrat = _alertes
                    .Where(a => string.IsNullOrEmpty(_cercaHistoric) ||
                                a.Text.Contains(_cercaHistoric, StringComparison.OrdinalIgnoreCase) ||
                                (a.Alumne?.Contains(_cercaHistoric, StringComparison.OrdinalIgnoreCase) ?? false))
                    .OrderByDescending(a => a.Hora)
                    .Take(100)
                    .ToList();
            }
            @if (historicFiltrat.Count == 0)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @(string.IsNullOrEmpty(_cercaHistoric)
                        ? "Sense events registrats en aquesta sessió"
                        : "Cap resultat per a la cerca")
                </MudText>
            }
            else
            {
                <div style="max-height:220px;overflow-y:auto;border:1px solid var(--mud-palette-lines-default);border-radius:4px">
                    @foreach (var entrada in historicFiltrat)
                    {
                        <div style="display:flex;align-items:center;gap:5px;padding:2px 6px;border-bottom:1px solid var(--mud-palette-lines-default)">
                            <MudIcon Icon="@entrada.Icona" Color="entrada.Color"
                                     Style="font-size:.9rem;flex-shrink:0" />
                            <span style="font-family:monospace;font-size:.7rem;color:var(--mud-palette-text-secondary);flex-shrink:0;min-width:50px">
                                @entrada.Hora.ToLocalTime().ToString("HH:mm:ss")
                            </span>
                            <span style="font-size:.75rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                                @entrada.Text
                            </span>
                        </div>
                    }
                </div>
            }
        </MudPaper>

    </MudItem>

    <!-- Pannell de detall de l'estació (apareix al costat) -->
    @if (_mostraDetall && _alumneSeleccionat is not null)
    {
        <MudItem xs="12" md="3">
            <MudPaper Elevation="4" Style="position:sticky;top:16px;border-radius:12px;overflow:hidden">

                <!-- Capçalera -->
                <div style="background:linear-gradient(135deg,#1e293b 0%,#0f172a 100%);padding:.875rem 1rem">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.subtitle1"
                                 Style="color:white;font-weight:700;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                            @(_alumneSeleccionat.Nom is not null
                                ? $"{_alumneSeleccionat.Cognoms}, {_alumneSeleccionat.Nom}"
                                : "Estació sense identificar")
                        </MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                       Style="color:rgba(255,255,255,.7);margin:-8px -8px -8px 0"
                                       Size="Size.Small"
                                       OnClick="() => { _mostraDetall = false; _alumneSeleccionat = null; }" />
                    </MudStack>
                </div>

                <MudStack Class="pa-3" Spacing="3">

                    <!-- Avatar + estat -->
                    <MudStack AlignItems="AlignItems.Center" Spacing="1">
                        @if (_alumneSeleccionat.FotoUrl is not null)
                        {
                            <MudAvatar Style="width:88px;height:88px">
                                <MudImage Src="@_alumneSeleccionat.FotoUrl"
                                          Style="width:88px;height:88px;object-fit:cover" />
                            </MudAvatar>
                        }
                        else
                        {
                            <MudAvatar Style="@($"width:88px;height:88px;background:{EstatColor(_alumneSeleccionat.Estat)}20;font-size:2rem;color:{EstatColor(_alumneSeleccionat.Estat)}")">
                                @(_alumneSeleccionat.Nom is not null
                                    ? (_alumneSeleccionat.Nom[..1] + (_alumneSeleccionat.Cognoms?[..1] ?? ""))
                                    : "?")
                            </MudAvatar>
                        }
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <div style="@($"width:10px;height:10px;border-radius:50%;background:{EstatColor(_alumneSeleccionat.Estat)}")"></div>
                            <MudText Typo="Typo.body2" Style="font-weight:600">
                                @EstatText(_alumneSeleccionat.Estat)
                            </MudText>
                        </MudStack>
                    </MudStack>

                    <!-- Dades de l'alumne (si identificat) -->
                    @if (_alumneSeleccionat.Nom is not null)
                    {
                        <MudDivider />
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary"
                                     Style="font-weight:700;text-transform:uppercase;letter-spacing:.05em">
                                Alumne
                            </MudText>
                            @if (_alumneSeleccionat.Email is not null)
                            {
                                <MudStack Row="true" Spacing="1">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width:72px">
                                        Correu
                                    </MudText>
                                    <MudText Typo="Typo.caption" Style="word-break:break-all">
                                        @_alumneSeleccionat.Email
                                    </MudText>
                                </MudStack>
                            }
                            @if (_alumneSeleccionat.NumLlista.HasValue)
                            {
                                <MudStack Row="true" Spacing="1">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width:72px">
                                        Núm. llista
                                    </MudText>
                                    <MudText Typo="Typo.caption">@_alumneSeleccionat.NumLlista</MudText>
                                </MudStack>
                            }
                            @if (_sessio is not null)
                            {
                                <MudStack Row="true" Spacing="1">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width:72px">
                                        Classe
                                    </MudText>
                                    <MudText Typo="Typo.caption">@_sessio.ClassName</MudText>
                                </MudStack>
                            }
                        </MudStack>
                    }

                    <!-- Dades de xarxa -->
                    <MudDivider />
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary"
                                 Style="font-weight:700;text-transform:uppercase;letter-spacing:.05em">
                            Xarxa
                        </MudText>
                        @{
                            var teMac = _alumneSeleccionat.MacAddress.Contains(':');
                        }
                        <MudStack Row="true" Spacing="1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width:72px">MAC</MudText>
                            <MudText Typo="Typo.caption" Style="font-family:monospace">
                                @(teMac ? _alumneSeleccionat.MacAddress : "—")
                            </MudText>
                        </MudStack>
                        <MudStack Row="true" Spacing="1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width:72px">IP</MudText>
                            <MudText Typo="Typo.caption" Style="font-family:monospace">
                                @(_alumneSeleccionat.IpAssignada ?? (!teMac ? _alumneSeleccionat.MacAddress : "—"))
                            </MudText>
                        </MudStack>
                        <MudStack Row="true" Spacing="1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width:72px">
                                Entrada
                            </MudText>
                            <MudText Typo="Typo.caption">
                                @_alumneSeleccionat.ConnectatAt.ToLocalTime().ToString("HH:mm:ss")
                            </MudText>
                        </MudStack>
                        @if (_alumneSeleccionat.UltimCheckinAt.HasValue)
                        {
                            <MudStack Row="true" Spacing="1">
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width:72px">
                                    Check-in
                                </MudText>
                                <MudText Typo="Typo.caption">
                                    @_alumneSeleccionat.UltimCheckinAt.Value.ToLocalTime().ToString("HH:mm:ss")
                                </MudText>
                            </MudStack>
                            <MudStack Row="true" Spacing="1">
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width:72px">
                                    Endarrer.
                                </MudText>
                                <MudText Typo="Typo.caption"
                                         Style="@ElapsedStyle(_alumneSeleccionat.UltimCheckinAt.Value)">
                                    @FormatElapsed((int)(_ara - _alumneSeleccionat.UltimCheckinAt.Value).TotalSeconds)
                                </MudText>
                            </MudStack>
                        }
                        @if (_alumneSeleccionat.BytesEnviats.HasValue || _alumneSeleccionat.NumRequestes.HasValue)
                        {
                            <MudStack Row="true" Spacing="1">
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width:72px">Tràfic</MudText>
                                <MudText Typo="Typo.caption" Style="font-family:monospace">
                                    @FormatBytes(_alumneSeleccionat.BytesEnviats ?? 0)
                                    <span style="color:var(--mud-palette-text-secondary)"> · @(_alumneSeleccionat.NumRequestes ?? 0) req</span>
                                </MudText>
                            </MudStack>
                        }
                    </MudStack>

                    <!-- Acció d'expulsió -->
                    @if (_sessio?.Activa == true && _alumneSeleccionat.StudentId.HasValue &&
                         _alumneSeleccionat.Estat != EstatConnexioDto.Desconnectat)
                    {
                        <MudDivider />
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" FullWidth="true"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.PersonRemove"
                                   OnClick="() => _confirmarExpulsio = true">
                            Expulsar alumne
                        </MudButton>
                    }

                    <!-- Peticions DNS -->
                    <MudDivider />
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary"
                                 Style="font-weight:700;text-transform:uppercase;letter-spacing:.05em">
                            @Loc["Examen_DnsRequests"]
                        </MudText>
                        @if (_alumneSeleccionat.DnsRecents.Count == 0)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @Loc["Examen_NoDns"]
                            </MudText>
                        }
                        else
                        {
                            @foreach (var dns in _alumneSeleccionat.DnsRecents
                                .OrderByDescending(d => d.Timestamp).Take(15))
                            {
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@(dns.EsExterna
                                                     ? Icons.Material.Filled.Warning
                                                     : Icons.Material.Filled.Check)"
                                             Color="@(dns.EsExterna ? Color.Warning : Color.Success)"
                                             Size="Size.Small" />
                                    <MudText Typo="Typo.caption">
                                        @dns.Timestamp.ToLocalTime().ToString("HH:mm:ss")
                                        — @dns.Domini
                                    </MudText>
                                </MudStack>
                            }
                        }
                    </MudStack>

                </MudStack>
            </MudPaper>
        </MudItem>
    }

</MudGrid>

<!-- Diàleg confirmació d'eliminació de sessió -->
<MudDialog @bind-Visible="_confirmarEliminarSessio">
    <TitleContent>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.DeleteForever" Color="Color.Error" />
            <MudText Typo="Typo.h6">Eliminar sessió tancada</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Warning">
            S'eliminarà la sessió
            <strong>@(_sessioAEliminar?.Titol ?? "sense títol")</strong>
            (@(_sessioAEliminar?.ClassName))
            i tots els registres de connexió associats. Aquesta acció no es pot desfer.
        </MudAlert>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _confirmarEliminarSessio = false">
            @Loc["Action_Cancel"]
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error"
                   OnClick="EliminarSessio" Disabled="_carregant">
            Eliminar
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Diàleg confirmació d'expulsió -->
<MudDialog @bind-Visible="_confirmarExpulsio">
    <TitleContent>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.PersonRemove" Color="Color.Error" />
            <MudText Typo="Typo.h6">Expulsar alumne</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Warning">
            Segur que vols expulsar
            <strong>@_alumneSeleccionat?.Nom @_alumneSeleccionat?.Cognoms</strong>
            de la sessió? L'alumne rebrà un avís i serà desconnectat.
        </MudAlert>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _confirmarExpulsio = false">
            @Loc["Action_Cancel"]
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error"
                   OnClick="ExpulsarAlumne" Disabled="_carregant">
            Expulsar
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Diàleg nova sessió -->
<MudDialog @bind-Visible="_mostrarDialegNovaSessio">
    <TitleContent>
        <MudText Typo="Typo.h6">@Loc["Examen_StartSessionTitle"]</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudSelect T="int" @bind-Value="_novaClasseId"
                       Label="@Loc["Examen_SelectClass"]"
                       Variant="Variant.Outlined">
                @foreach (var c in _classes)
                {
                    <MudSelectItem Value="@c.Id">@c.Name</MudSelectItem>
                }
            </MudSelect>
            <MudTextField @bind-Value="_novaTitol"
                          Label="@Loc["Examen_SessionTitle"]"
                          Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_novaDescripcio"
                          Label="@Loc["Examen_Instructions"]"
                          Variant="Variant.Outlined" Lines="3" />
        </MudStack>
        @if (_errorNovaSessio is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mt-2">@_errorNovaSessio</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _mostrarDialegNovaSessio = false">
            @Loc["Action_Cancel"]
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success"
                   OnClick="IniciarSessio" Disabled="_carregant">
            @Loc["Examen_Start"]
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Diàleg missatge professor -->
<MudDialog @bind-Visible="_mostrarDialegMissatge">
    <TitleContent>
        <MudText Typo="Typo.h6">@Loc["Examen_MessageTitle"]</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_textMissatge"
                      Label="@Loc["Examen_MessageLabel"]"
                      Variant="Variant.Outlined" Lines="3"
                      MaxLength="500" Counter="500"
                      OnKeyDown="OnMissatgeKeyDown" />
        @if (_sessio?.MissatgeActiu is not null)
        {
            <MudAlert Severity="Severity.Info" Class="mt-2" Dense="true">
                @Loc["Examen_CurrentMessage"] <em>@_sessio.MissatgeActiu</em>
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        @if (_sessio?.MissatgeActiu is not null)
        {
            <MudButton Color="Color.Error" OnClick="EsborrarMissatge">
                @Loc["Examen_DeleteMessage"]
            </MudButton>
        }
        <MudButton OnClick="() => _mostrarDialegMissatge = false">
            @Loc["Action_Cancel"]
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Warning"
                   OnClick="EnviarMissatge"
                   Disabled="string.IsNullOrWhiteSpace(_textMissatge)">
            @Loc["Action_Send"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<SessioExamenDto>  _sessions = [];
    private List<ClassDto>         _classes  = [];
    private List<ExamenAlumneDto>  _alumnes  = [];
    private List<AlertaExamen>     _alertes  = [];
    private SessioExamenDto?       _sessio;
    private ExamenAlumneDto?       _alumneSeleccionat;

    private int?   _sessioId;
    private bool   _carregant;
    private bool   _mostraDetall;

    private bool    _mostrarDialegNovaSessio;
    private bool    _mostrarDialegMissatge;
    private int     _novaClasseId;
    private string  _novaTitol     = "";
    private string  _novaDescripcio = "";
    private string? _errorNovaSessio;
    private string  _textMissatge  = "";

    private string              _cerca      = "";
    private EstatConnexioDto?   _filtreEstat;
    private bool                _confirmarExpulsio;
    private bool                _confirmarEliminarSessio;
    private SessioExamenDto?    _sessioAEliminar;
    private bool                _mostrarSessions = true;
    private string              _cercaHistoric   = "";

    private Func<string, object, Task>? _sessioHandler;
    private System.Threading.Timer?     _refreshTimer;
    private System.Threading.Timer?     _uiTimer;
    private HashSet<string>             _sortideVoluntaries = [];
    private DateTime                    _ara = DateTime.UtcNow;
    private string                      _dhcpPrefix = "192.168.100.";
    private bool                        _historicInicialitzat;

    private int _connectats => _alumnes.Count(a =>
        a.Estat is EstatConnexioDto.Connectat or EstatConnexioDto.SenseCheckin);

    private IEnumerable<ExamenAlumneDto> _alumnesFiltrats => _alumnes
        .Where(a => (string.IsNullOrWhiteSpace(_cerca) ||
                     $"{a.Nom} {a.Cognoms}".Contains(_cerca, StringComparison.OrdinalIgnoreCase) ||
                     (a.Email?.Contains(_cerca, StringComparison.OrdinalIgnoreCase) ?? false))
                 && (_filtreEstat is null || a.Estat == _filtreEstat))
        .OrderBy(a => a.Estat switch
        {
            EstatConnexioDto.Connectat    => 0,
            EstatConnexioDto.SenseCheckin => 1,
            EstatConnexioDto.Desconnectat => 2,
            _                            => 3
        })
        .ThenBy(a => a.NumLlista ?? int.MaxValue)
        .ThenBy(a => a.Cognoms);

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsProfessor) return;
        Api.SetToken(UserState.Token!);
        _dhcpPrefix = Config["Examen:DhcpNetworkPrefix"] ?? "192.168.100.";
        _carregant = true;
        _classes   = await Api.GetClassesAsync() ?? [];
        _sessions  = await Api.GetExamenSessionsAsync() ?? [];

        var activa = _sessions.FirstOrDefault(s => s.Activa);
        if (activa is not null)
            await SeleccionarSessio(activa.Id);

        _carregant = false;

        _uiTimer = new System.Threading.Timer(async _ =>
            await InvokeAsync(() => { _ara = DateTime.UtcNow; StateHasChanged(); }),
            null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private async Task SeleccionarSessio(int? id)
    {
        if (id is null) return;
        if (id == _sessioId) { await CarregarDashboard(); return; }

        if (_sessioId.HasValue && _sessioHandler is not null)
            ExamenNotif.DesubscriuSessio(_sessioId.Value, _sessioHandler);

        _sessioId = id;
        _alertes.Clear();
        _cercaHistoric = "";
        _historicInicialitzat = false;
        await CarregarDashboard();

        _sessioHandler = async (eventNom, data) =>
            await ProcessarEventAsync(eventNom, data);
        ExamenNotif.SubscriuSessio(_sessioId.Value, _sessioHandler);

        // Auto-refresh cada 30 s com a fallback si Redis no publica
        // Tota la mutació de l'estat passa dins InvokeAsync per garantir thread-safety a Blazor Server
        _refreshTimer?.Dispose();
        _refreshTimer = new System.Threading.Timer(async _ =>
            await InvokeAsync(async () =>
            {
                await CarregarDashboard();
                StateHasChanged();
            }),
            null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private async Task CarregarDashboard()
    {
        if (_sessioId is null) return;
        var dashboard = await Api.GetExamenDashboardAsync(_sessioId.Value);
        if (dashboard is null) return;
        _sessio  = dashboard.Sessio;
        _alumnes = dashboard.Alumnes;
        var macs = _alumnes.Select(a => a.MacAddress).ToHashSet();
        _sortideVoluntaries.IntersectWith(macs);

        // Inicialitza l'historial amb l'estat actual (només en la primera càrrega de cada sessió)
        if (!_historicInicialitzat)
        {
            _historicInicialitzat = true;
            foreach (var a in _alumnes
                .Where(a => a.Estat != EstatConnexioDto.NoConnectat)
                .OrderBy(a => a.ConnectatAt))
            {
                var nom = a.Nom is not null ? $"{a.Nom} {a.Cognoms}".Trim() : a.MacAddress;
                AfegirAlerta($"Connectat: {nom} ({a.IpAssignada ?? a.MacAddress})",
                    Icons.Material.Filled.Link, Color.Success, nom);
                if (a.UltimCheckinAt.HasValue)
                    AfegirAlerta($"Check-in: {nom}",
                        Icons.Material.Filled.CheckCircle, Color.Success, nom);
                if (a.Estat == EstatConnexioDto.Desconnectat)
                    AfegirAlerta($"Desconnectat: {nom}",
                        Icons.Material.Filled.LinkOff, Color.Error, nom);
            }
        }
    }

    private async Task ProcessarEventAsync(string eventNom, object data)
    {
        switch (eventNom)
        {
            case "AlumneConnectat" when data is ExamenEventAlumne evt:
            {
                var nomAlerta = $"{evt.Nom} {evt.Cognoms}".Trim();
                if (string.IsNullOrEmpty(nomAlerta)) nomAlerta = evt.Mac ?? evt.Ip ?? "?";
                if (!ActualitzarAlumne(evt.Mac, a => a with
                    { Estat = EstatConnexioDto.Connectat, IpAssignada = evt.Ip }))
                    await CarregarDashboard();
                AfegirAlerta($"Connectat: {nomAlerta} ({evt.Ip})",
                    Icons.Material.Filled.Link, Color.Success,
                    string.IsNullOrEmpty($"{evt.Nom} {evt.Cognoms}".Trim()) ? null : $"{evt.Nom} {evt.Cognoms}".Trim());
                break;
            }
            case "AlumneDesconnectat" when data is ExamenEventAlumne evt:
            {
                var nom = $"{evt.Nom} {evt.Cognoms}".Trim();
                ActualitzarAlumne(evt.Mac, a => a with { Estat = EstatConnexioDto.Desconnectat });
                AfegirAlerta($"Desconnectat: {nom}",
                    Icons.Material.Filled.LinkOff, Color.Error, nom);
                Snackbar.Add($"Desconnectat: {nom}", Severity.Error,
                    cfg => { cfg.DuplicatesBehavior = SnackbarDuplicatesBehavior.Allow; cfg.VisibleStateDuration = 6000; });
                await JS.InvokeVoidAsync("examenSoDesconnexio");
                break;
            }
            case "AlumneDesconnectatVoluntari" when data is ExamenEventAlumne evt:
            {
                var nom = $"{evt.Nom} {evt.Cognoms}".Trim();
                _sortideVoluntaries.Add(evt.Mac);
                ActualitzarAlumne(evt.Mac, a => a with { Estat = EstatConnexioDto.Desconnectat });
                AfegirAlerta($"Ha sortit voluntàriament: {nom}",
                    Icons.Material.Filled.ExitToApp, Color.Warning, nom);
                Snackbar.Add($"Sortida voluntària: {nom}", Severity.Warning,
                    cfg => { cfg.DuplicatesBehavior = SnackbarDuplicatesBehavior.Allow; cfg.VisibleStateDuration = 6000; });
                break;
            }
            case "NouCheckin" when data is ExamenEventAlumne evt:
            {
                var trobat = ActualitzarAlumne(evt.Mac, a => a with
                    { Estat = EstatConnexioDto.Connectat, UltimCheckinAt = evt.Timestamp });
                if (!trobat)
                {
                    // Primer check-in sense DHCP previ → l'alumne no era a la llista
                    await CarregarDashboard();
                    AfegirAlerta($"Connectat: {evt.Nom} {evt.Cognoms} ({evt.Ip})",
                        Icons.Material.Filled.Link, Color.Success,
                        $"{evt.Nom} {evt.Cognoms}".Trim());
                }
                break;
            }
            case "NovaPeticioExterna" when data is ExamenEventDns evt:
                AfegirAlerta($"DNS externa: {evt.Nom} → {evt.Domini}",
                    Icons.Material.Filled.Warning, Color.Warning, evt.Nom);
                break;
            case "MacDesconeguda" when data is ExamenEventAlumne evt:
                AfegirAlerta($"MAC desconeguda: {evt.Mac} ({evt.Ip})",
                    Icons.Material.Filled.DeviceUnknown, Color.Secondary);
                await CarregarDashboard();
                break;
            case "MissatgeActualitzat" when data is ExamenEventMissatge msg:
                if (_sessio is not null) _sessio = _sessio with { MissatgeActiu = msg.Text };
                break;
        }

        await InvokeAsync(StateHasChanged);
    }

    private bool ActualitzarAlumne(string mac, Func<ExamenAlumneDto, ExamenAlumneDto> update)
    {
        var idx = _alumnes.FindIndex(a => a.MacAddress == mac);
        if (idx < 0) return false;
        _alumnes[idx] = update(_alumnes[idx]);
        if (_alumneSeleccionat?.MacAddress == mac)
            _alumneSeleccionat = _alumnes[idx];
        return true;
    }

    private void AfegirAlerta(string text, string icona, Color color, string? alumne = null)
    {
        _alertes.Add(new AlertaExamen(text, icona, color, DateTime.UtcNow, alumne));
        if (_alertes.Count > 200) _alertes.RemoveRange(0, _alertes.Count - 200);
    }

    private async Task IniciarSessio()
    {
        _errorNovaSessio = null;
        if (_novaClasseId == 0)
        {
            _errorNovaSessio = Loc["Examen_SelectClass"].Value + " és obligatòria.";
            return;
        }
        _carregant = true;
        var (sessio, error) = await Api.CreateExamenSessioAsync(
            new CreateSessioRequest(_novaClasseId, _novaTitol, _novaDescripcio));
        _carregant = false;

        if (error is not null) { _errorNovaSessio = error; return; }

        _mostrarDialegNovaSessio = false;
        _novaTitol = ""; _novaDescripcio = ""; _novaClasseId = 0;
        _sessions = await Api.GetExamenSessionsAsync() ?? [];
        if (sessio is not null)
            await SeleccionarSessio(sessio.Id);
    }

    private async Task TancarSessio()
    {
        if (_sessioId is null) return;
        await Api.TancarExamenSessioAsync(_sessioId.Value);
        _sessions = await Api.GetExamenSessionsAsync() ?? [];
        await CarregarDashboard();
        StateHasChanged();
    }

    private async Task ReobrirSessio()
    {
        if (_sessioId is null) return;
        await Api.ReobrirExamenSessioAsync(_sessioId.Value);
        _sessions = await Api.GetExamenSessionsAsync() ?? [];
        await CarregarDashboard();
        StateHasChanged();
    }

    private async Task OnMissatgeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await EnviarMissatge();
    }

    private async Task EnviarMissatge()
    {
        if (_sessioId is null || string.IsNullOrWhiteSpace(_textMissatge)) return;
        await Api.SetMissatgeExamenAsync(_sessioId.Value, _textMissatge);
        _mostrarDialegMissatge = false;
        _textMissatge          = "";
    }

    private async Task EliminarSessio()
    {
        if (_sessioAEliminar is null) return;
        _confirmarEliminarSessio = false;
        _carregant = true;
        await Api.EliminarExamenSessioAsync(_sessioAEliminar.Id);
        _carregant = false;

        if (_sessioId == _sessioAEliminar.Id)
        {
            _sessioId          = null;
            _sessio            = null;
            _alumnes           = [];
            _mostraDetall      = false;
            _alumneSeleccionat = null;
            _alertes.Clear();
            _cercaHistoric     = "";
        }
        _sessioAEliminar = null;
        _sessions = await Api.GetExamenSessionsAsync() ?? [];
        if (_sessioId is null)
        {
            var activa = _sessions.FirstOrDefault(s => s.Activa);
            if (activa is not null)
                await SeleccionarSessio(activa.Id);
        }
        StateHasChanged();
    }

    private async Task ExpulsarAlumne()
    {
        if (_sessioId is null || _alumneSeleccionat?.StudentId is null) return;
        _confirmarExpulsio = false;
        _carregant = true;
        await Api.ExpulsarAlumneAsync(_sessioId.Value, _alumneSeleccionat.StudentId.Value);
        _carregant = false;
        _mostraDetall      = false;
        _alumneSeleccionat = null;
        await CarregarDashboard();
        StateHasChanged();
    }

    private async Task EsborrarMissatge()
    {
        if (_sessioId is null) return;
        await Api.DeleteMissatgeExamenAsync(_sessioId.Value);
        if (_sessio is not null) _sessio = _sessio with { MissatgeActiu = null };
        _mostrarDialegMissatge = false;
    }

    private async Task ExportarCsv()
    {
        if (_sessioId is null) return;
        var result = await Api.ExportarExamenCsvAsync(_sessioId.Value);
        if (result is null) return;
        var (bytes, fileName) = result.Value;
        var b64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadFileFromBase64", b64, fileName, "text/csv");
    }

    private async Task EntrarModePresentacio()
    {
        await JS.InvokeVoidAsync("document.documentElement.requestFullscreen");
        StateHasChanged();
    }

    private void SeleccionarAlumne(ExamenAlumneDto a)
    {
        _alumneSeleccionat = a;
        _mostraDetall      = true;
    }

    private bool EsIpDhcp(string? ip)
    {
        if (string.IsNullOrEmpty(ip)) return true;
        return ip.StartsWith(_dhcpPrefix, StringComparison.Ordinal);
    }

    private static string EstatColor(EstatConnexioDto estat) => estat switch
    {
        EstatConnexioDto.Connectat    => "#22c55e",
        EstatConnexioDto.SenseCheckin => "#f59e0b",
        EstatConnexioDto.Desconnectat => "#ef4444",
        _                            => "#9ca3af"
    };

    private string EstatText(EstatConnexioDto estat) => estat switch
    {
        EstatConnexioDto.Connectat    => Loc["Examen_Status_Connectat"].Value,
        EstatConnexioDto.SenseCheckin => Loc["Examen_Status_SenseCheckin"].Value,
        EstatConnexioDto.Desconnectat => Loc["Examen_Status_Desconnectat"].Value,
        _                            => Loc["Examen_Status_NoConnectat"].Value
    };

    private void NetejarHistoric()
    {
        _alertes.Clear();
        _cercaHistoric = "";
    }

    private string ElapsedStyle(DateTime ultimCheckin)
    {
        var elapsed  = (int)(_ara - ultimCheckin).TotalSeconds;
        var interval = _sessio?.IntervalSegons ?? 30;
        return elapsed > interval * 2 ? "color:#dc2626;font-weight:600"
             : elapsed > interval     ? "color:#b45309;font-weight:600"
             : "color:#6b7280";
    }

    private static string FormatElapsed(int seconds)
    {
        if (seconds < 0) seconds = 0;
        return seconds < 60 ? $"fa {seconds}s" : $"fa {seconds / 60}m {seconds % 60}s";
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes >= 1_048_576) return $"{bytes / 1_048_576.0:F1} MB";
        if (bytes >= 1_024)     return $"{bytes / 1_024.0:F1} KB";
        return $"{bytes} B";
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
        _uiTimer?.Dispose();
        if (_sessioId.HasValue && _sessioHandler is not null)
            ExamenNotif.DesubscriuSessio(_sessioId.Value, _sessioHandler);
    }

    private sealed record AlertaExamen(
        string Text, string Icona, Color Color, DateTime Hora, string? Alumne = null);
}
