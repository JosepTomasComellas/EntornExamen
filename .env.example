# =============================================================================
# EntornExamen — Fitxer de configuració
# Copia aquest fitxer a .env i edita els valors. Les variables marcades amb
# [OBLIGATORI] fan fallar l'arrencada si estan buides o amb el valor exemple.
# =============================================================================

# ── Base de dades SQL Server ─────────────────────────────────────────────────
# [OBLIGATORI] Mínim 8 caràcters, ha de tenir majúscules, minúscules i números
MSSQL_SA_PASSWORD=CanviaAquestaContrasenya_2024!

# ── JWT ──────────────────────────────────────────────────────────────────────
# [OBLIGATORI] Mínim 32 caràcters aleatoris
JWT_SECRET=CanviaAquestSecret_MiniM32Caracters_2024
JWT_EXPIRY_HOURS=8

# ── Compte administrador ─────────────────────────────────────────────────────
# [OBLIGATORI] Correu electrònic de l'administrador
ADMIN_EMAIL=admin@domini.cat
# [OBLIGATORI] Contrasenya de l'administrador (mínim 8 caràcters)
ADMIN_PASSWORD=CanviaAquestaContrasenya123!
# Nom i cognoms de l'administrador (opcional però recomanat)
ADMIN_NOM=Administrador
ADMIN_COGNOMS=

# ── SMTP (correu) ─────────────────────────────────────────────────────────────
# Opcional: si no es configura, l'enviament de correus es desactiva silenciosament
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=el-teu-correu@gmail.com
SMTP_PASSWORD=contrasenya-aplicacio-gmail
SMTP_FROM_ADDRESS=el-teu-correu@gmail.com
SMTP_FROM_NAME=Nom del Centre - Dept. Informàtica

# ── URLs ──────────────────────────────────────────────────────────────────────
# URL pública de l'aplicació web (usada en correus de recuperació de contrasenya)
APP_WEB_URL=https://192.168.100.1:4445

# ── Sistema ───────────────────────────────────────────────────────────────────
TZ=Europe/Madrid
# Nivell de log dels contenidors (Debug/Information/Warning/Error/Critical)
# Warning oculta els Info de frameworks (.NET, EF, SignalR).
# Els logs propis de l'aplicació sempre es mostren en nivell Information.
LOG_LEVEL=Warning

# ── Marca / Branding ─────────────────────────────────────────────────────────
# Nom complet de l'aplicació (títol, manifest PWA, footer)
BRAND_NOM=Entorn d'Examens
# Nom curt per al manifest PWA (icona a la pantalla d'inici)
BRAND_SHORT_NOM=Examens
# Nom de l'organització (footer)
BRAND_ORGANITZACIO=Salesians de Sarrià · Dept. d'Informàtica
# Colors corporatius (hex, ex: #CC0000 per vermell, #003087 per blau)
BRAND_COLOR_PRIMARY=#CC0000
BRAND_COLOR_APPBAR=#1e293b
# URL del logo (relativa al servidor web; /branding/logo.png per a logos personalitzats)
BRAND_LOGO_URL=/images/logo2.png
# URL de la imatge de fons (deixar en blanc per desactivar el fons)
BRAND_BG_IMAGE_URL=/images/fons-salesians.png
# Per usar logos i fons personalitzats: posa els fitxers a la carpeta ./branding/
# i ajusta BRAND_LOGO_URL=/branding/logo.png i BRAND_BG_IMAGE_URL=/branding/fons.jpg

# ── Entorn Examen — Xarxa ─────────────────────────────────────────────────────
# IP del servidor a la xarxa d'examen (usada per redireccions DNS i com a gateway)
EXAMEN_SERVER_IP=192.168.100.1
# Prefix de la xarxa DHCP (per detectar IPs fora de rang al plafó del professor)
EXAMEN_DHCP_NETWORK_PREFIX=192.168.100.
# Domini DNS intern de la xarxa d'examen (peticions a aquest domini no es marquen com a externes)
EXAMEN_DNS_LOCAL_DOMAIN=examen.local
# Domini dels correus corporatius dels alumnes (peticions amb @ d'altri es rebutgen)
EXAMEN_DOMINI_EMAIL=sarria.salesians.cat

# ── Entorn Examen — Temporitzadors ───────────────────────────────────────────
# Interval de check-in dels alumnes en segons (per defecte: 30)
EXAMEN_CHECKIN_INTERVAL_SECONDS=30
# Factor per passar a SenseCheckin: interval × factor (per defecte: 2 → 60s sense check-in). Accepta decimals (ex: 1.5)
EXAMEN_SENSE_CHECKIN_FACTOR=2
# Factor per passar a Desconnectat: interval × factor (per defecte: 4 → 120s sense check-in). Accepta decimals (ex: 3.5)
EXAMEN_DESCONNECTAT_FACTOR=4
# Temps (en segons) d'espera sense reconnexió de circuit Blazor abans de marcar desconnectat
EXAMEN_CIRCUIT_GRACE_PERIOD_SECONDS=90
# Dies de retenció de sessions tancades abans d'eliminar-les (per defecte: 30)
EXAMEN_CLEANUP_RETENTION_DAYS=30

# ── Entorn Examen — Avançat ───────────────────────────────────────────────────
# Mode de proves: permet múltiples alumnes amb la mateixa IP (per a tests locals)
EXAMEN_MODE_PRO=false
# Contenidors visibles al visor de logs (llista separada per comes)
#DOCKER_ALLOWED_CONTAINERS=entornexamen-api,entornexamen-web,entornexamen-nginx,entornexamen-db,entornexamen-redis
# Token secret per a les crides internes web → api (sortida-circuit, alerta-circuit).
# Opcional: si es deixa buit, els endpoints interns no exigeixen autenticació (per xarxa Docker aïllada).
# Recomanat en desplegaments exposats a internet. Generar amb: openssl rand -hex 32
#EXAMEN_INTERNAL_API_TOKEN=
