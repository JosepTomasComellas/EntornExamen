# Nivell de log dels contenidors (Debug/Information/Warning/Error/Critical)
# Warning oculta els Info de frameworks (.NET, EF, SignalR). Els logs propis de
# l'aplicació (EntornExamen.*) sempre es mostren en nivell Information.
LOG_LEVEL=Warning

# ── Entorn Examen ─────────────────────────────────────────────────────────────
EXAMEN_CHECKIN_INTERVAL_SECONDS=30
EXAMEN_SENSE_CHECKIN_FACTOR=2
EXAMEN_DESCONNECTAT_FACTOR=4
EXAMEN_DOMINI_EMAIL=sarria.salesians.cat
EXAMEN_DHCP_NETWORK_PREFIX=192.168.100.
# Mode de proves: permet múltiples alumnes amb la mateixa IP (per a tests locals)
EXAMEN_MODE_PRO=false
